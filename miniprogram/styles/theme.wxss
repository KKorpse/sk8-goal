/**
 * SkateGoal 主题变量
 * 柔和3D风格 (Soft 3D / Claymorphism)
 */

page {
  /* 主色调 - 柔和版 */
  --primary-purple: #9D74FF;
  --primary-yellow: #FFD23F;
  --primary-cyan: #3DD1E7;
  --primary-orange: #FF8A3D;
  --primary-green: #4ade80;
  --primary-red: #f87171;
  
  /* 背景色 - 深棕色 */
  --bg-dark: #3A2E24; 
  --bg-darker: #2A2018;
  --bg-card: #E8E8E8; /* 卡片底色 */
  --bg-card-light: #F5F5F5;
  --bg-card-hover: #DCDCDC;
  --bg-surface: #D1D1D1;
  --bg-surface-dark: #A3A3A3;
  
  /* 文字色 - 柔和 */
  --text-primary: #333333;
  --text-primary-light: #ffffff;
  --text-secondary: #666666;
  --text-secondary-light: #dddddd;
  --text-muted: #999999;
  --text-dark: #1f1f1f;
  
  /* 状态色 - 柔和版 */
  --status-trial: #3b82f6;      
  --status-grinding: #FF8A3D;   
  --status-mastered: #4ade80;   
  --status-none: #9ca3af;       
  
  /* 状态色柔和版 - 用于背景 */
  --status-trial-bg: rgba(59, 130, 246, 0.15);
  --status-grinding-bg: rgba(255, 138, 61, 0.15);
  --status-mastered-bg: rgba(74, 222, 128, 0.15);
  
  /* 强调色 */
  --accent-glow: #f87171;
  --accent-success: #4ade80;
  --border-color: #D1D1D1; /* 柔和边框 */
  --border-light: #E8E8E8;
  
  /* 渐变 */
  --gradient-purple: #9D74FF;
  --gradient-yellow: #FFD23F;
  --gradient-cyan: #3DD1E7;
  --gradient-card: #E8E8E8;
  
  /* 阴影 (柔和3D 风格) */
  --shadow-sm: inset 2rpx 2rpx 4rpx rgba(255,255,255,0.8), inset -2rpx -2rpx 4rpx rgba(0,0,0,0.1), 2rpx 4rpx 8rpx rgba(0,0,0,0.15);
  --shadow-md: inset 4rpx 4rpx 8rpx rgba(255,255,255,0.9), inset -4rpx -4rpx 8rpx rgba(0,0,0,0.15), 0 8rpx 16rpx rgba(0,0,0,0.3);
  --shadow-lg: inset 6rpx 6rpx 12rpx rgba(255,255,255,0.9), inset -6rpx -6rpx 12rpx rgba(0,0,0,0.15), 0 12rpx 24rpx rgba(0,0,0,0.4);
  --shadow-purple: inset 4rpx 4rpx 8rpx rgba(255,255,255,0.4), inset -4rpx -4rpx 8rpx rgba(157,116,255,0.4), 0 8rpx 16rpx rgba(157,116,255,0.4);
  --shadow-yellow: inset 4rpx 4rpx 8rpx rgba(255,255,255,0.4), inset -4rpx -4rpx 8rpx rgba(255,210,63,0.4), 0 8rpx 16rpx rgba(255,210,63,0.4);
  --shadow-cyan: inset 4rpx 4rpx 8rpx rgba(255,255,255,0.4), inset -4rpx -4rpx 8rpx rgba(61,209,231,0.4), 0 8rpx 16rpx rgba(61,209,231,0.4);
  --shadow-pressed: inset 4rpx 4rpx 8rpx rgba(0,0,0,0.15), inset -4rpx -4rpx 8rpx rgba(255,255,255,0.8);
  --shadow-text: none;
  --shadow-text-bold: none;
  
  /* 圆角 (柔和3D 风格) */
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --radius-full: 9999rpx;
  
  /* 间距 - 统一系统 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-section: 32rpx;    /* 模块间距 */
  --spacing-card: 24rpx;       /* 卡片间距 */
  --spacing-inner: 28rpx;      /* 卡片内间距 */
  --spacing-item: 16rpx;       /* 列表项间距 */
  
  /* 字号 - 精简层级 */
  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 44rpx;
  --font-3xl: 52rpx;
  
  /* 过渡动画 - 添加必要动画 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.35s ease;
  --transition-bounce: 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  
  /* 图标大小 */
  --icon-sm: 32rpx;
  --icon-md: 40rpx;
  --icon-lg: 48rpx;
  --icon-xl: 56rpx;
  
  /* 底部安全距离 */
  --safe-area-bottom: calc(180rpx + env(safe-area-inset-bottom));
  --safe-area-bottom-sm: calc(40rpx + env(safe-area-inset-bottom));
}
