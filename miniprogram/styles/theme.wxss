/**
 * SkateGoal 主题变量
 * Minecraft 风格配色方案
 */

page {
  /* 主色调 (Minecraft) */
  --primary-purple: #AA00AA; /* MC Purple */
  --primary-yellow: #FFFF55; /* MC Yellow */
  --primary-cyan: #55FFFF;   /* MC Aqua */
  --primary-orange: #FFAA00; /* MC Gold */
  --primary-green: #55FF55;  /* MC Green */
  --primary-red: #FF5555;    /* MC Red */
  
  /* 背景色 */
  --bg-dark: #3b2818; /* Dirt background color */
  --bg-card: #c6c6c6; /* Stone/UI background */
  --bg-card-light: #d8d8d8;
  --bg-surface: #8b8b8b; /* Darker stone */
  
  /* 文字色 */
  --text-primary: #ffffff;
  --text-secondary: #e0e0e0;
  --text-muted: #a0a0a0;
  --text-dark: #3f3f3f;
  
  /* 状态色 */
  --status-trial: #55FFFF;
  --status-grinding: #FFAA00;
  --status-mastered: #55FF55;
  --status-none: #555555;
  
  /* 强调色 */
  --accent-glow: #FF5555;
  --accent-success: #55FF55;
  --border-color: #000000; /* True black for MC borders */
  
  /* 渐变 (MC 通常不怎么用渐变，但保留变量以兼容) */
  --gradient-purple: #AA00AA;
  --gradient-yellow: #FFFF55;
  --gradient-cyan: #55FFFF;
  --gradient-card: #c6c6c6;
  
  /* 阴影 (MC 风格 3D 边框) */
  --shadow-sm: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
  --shadow-md: inset 6rpx 6rpx 0px 0px #ffffff, inset -6rpx -6rpx 0px 0px #555555, 4rpx 4rpx 0px 0px #000000;
  --shadow-lg: inset 8rpx 8rpx 0px 0px #ffffff, inset -8rpx -8rpx 0px 0px #555555, 8rpx 8rpx 0px 0px #000000;
  --shadow-purple: inset 4rpx 4rpx 0px 0px #FF55FF, inset -4rpx -4rpx 0px 0px #550055;
  --shadow-yellow: inset 4rpx 4rpx 0px 0px #FFFFaa, inset -4rpx -4rpx 0px 0px #aa5500;
  --shadow-cyan: inset 4rpx 4rpx 0px 0px #aaffff, inset -4rpx -4rpx 0px 0px #00aaaa;
  --shadow-text: none;
  --shadow-text-bold: 2rpx 2rpx 0px #3f3f3f; /* Only for white/light text */
  
  /* 圆角 (MC 风格没有圆角) */
  --radius-sm: 0rpx;
  --radius-md: 0rpx;
  --radius-lg: 0rpx;
  --radius-xl: 0rpx;
  --radius-full: 0rpx;
  
  /* 间距 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 20rpx;
  --spacing-lg: 28rpx;
  --spacing-xl: 40rpx;
  
  /* 字号 */
  --font-xs: 22rpx;
  --font-sm: 26rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 40rpx;
  --font-3xl: 48rpx;
  --font-4xl: 56rpx;
  
  /* 过渡动画 */
  --transition-fast: none; /* MC UI 很多是没有过渡的 */
  --transition-normal: none;
  --transition-slow: none;
  --transition-bounce: none;
}
