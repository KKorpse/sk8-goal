/**
 * SkateGoal 主题变量
 * 基础变量 + 主题覆盖
 */

page,
.theme-shell {
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-section: 32rpx;
  --spacing-card: 24rpx;
  --spacing-inner: 28rpx;
  --spacing-item: 16rpx;

  --font-xs: 20rpx;
  --font-sm: 24rpx;
  --font-base: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-2xl: 44rpx;
  --font-3xl: 52rpx;

  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.35s ease;
  --transition-bounce: 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);

  --icon-sm: 32rpx;
  --icon-md: 40rpx;
  --icon-lg: 48rpx;
  --icon-xl: 56rpx;

  --safe-area-bottom: calc(180rpx + env(safe-area-inset-bottom));
  --safe-area-bottom-sm: calc(40rpx + env(safe-area-inset-bottom));
}

page,
.theme-minecraft {
  --font-family-base: 'Courier New', Courier, monospace, 'PingFang SC', sans-serif;

  --primary-purple: #aa00aa;
  --primary-yellow: #ffff55;
  --primary-cyan: #00cccc;
  --primary-orange: #ffaa00;
  --primary-green: #44dd44;
  --primary-red: #ff5555;

  --bg-dark: #3b2818;
  --bg-darker: #2d1e11;
  --bg-card: #c6c6c6;
  --bg-card-light: #d8d8d8;
  --bg-card-hover: #b8b8b8;
  --bg-surface: #8b8b8b;
  --bg-surface-dark: #6b6b6b;
  --page-background-image:
    radial-gradient(circle at 25% 25%, rgba(74, 53, 32, 0.8) 2rpx, transparent 2rpx),
    radial-gradient(circle at 75% 75%, rgba(45, 30, 17, 0.6) 2rpx, transparent 2rpx);

  --text-primary: #2a2a2a;
  --text-primary-light: #ffffff;
  --text-secondary: #555555;
  --text-secondary-light: #cccccc;
  --text-muted: #888888;
  --text-dark: #3f3f3f;

  --status-trial: #00aaaa;
  --status-grinding: #ff8800;
  --status-mastered: #22aa44;
  --status-none: #666666;
  --status-trial-bg: rgba(0, 170, 170, 0.15);
  --status-grinding-bg: rgba(255, 136, 0, 0.15);
  --status-mastered-bg: rgba(34, 170, 68, 0.15);

  --accent-glow: #ff5555;
  --accent-success: #55ff55;
  --border-color: #000000;
  --border-light: #555555;
  --text-shadow-strong: 2rpx 2rpx 0 #000000;
  --text-shadow-soft: 1rpx 1rpx 0 #000000;

  --gradient-purple: #aa00aa;
  --gradient-yellow: #ffff55;
  --gradient-cyan: #00cccc;
  --gradient-card: #c6c6c6;

  --shadow-sm: inset 4rpx 4rpx 0 0 #ffffff, inset -4rpx -4rpx 0 0 #555555;
  --shadow-md: inset 6rpx 6rpx 0 0 #ffffff, inset -6rpx -6rpx 0 0 #555555, 4rpx 4rpx 0 0 #000000;
  --shadow-lg: inset 8rpx 8rpx 0 0 #ffffff, inset -8rpx -8rpx 0 0 #555555, 8rpx 8rpx 0 0 #000000;
  --shadow-purple: inset 4rpx 4rpx 0 0 #ff55ff, inset -4rpx -4rpx 0 0 #550055;
  --shadow-yellow: inset 4rpx 4rpx 0 0 #ffffaa, inset -4rpx -4rpx 0 0 #aa5500;
  --shadow-cyan: inset 4rpx 4rpx 0 0 #66eeee, inset -4rpx -4rpx 0 0 #008888;
  --shadow-pressed: inset 4rpx 4rpx 0 0 #555555, inset -4rpx -4rpx 0 0 #ffffff;
  --shadow-text: none;
  --shadow-text-bold: 2rpx 2rpx 0 #ffffff;
  --button-danger-highlight: #ffaaaa;
  --button-danger-shadow: #aa0000;
  --button-success-highlight: #48bb78;
  --button-success-shadow: #276749;
  --button-neutral-highlight: #c6c6c6;
  --button-neutral-shadow: #555555;
  --scene-sky-start: #5c94fc;
  --scene-sky-end: #87ceeb;
  --scene-ground-start: #5cb85c;
  --scene-ground-end: #4a9f4a;
  --scene-ground-border: #2d5016;
  --scene-soil-start: #8b5a2b;
  --scene-soil-end: #6b4423;
  --scene-soil-border: #5a3a1a;
  --scene-card-accent: #e89b3c;
  --scene-card-highlight: #f0b860;
  --scene-card-shadow: #a06020;

  --radius-sm: 0rpx;
  --radius-md: 0rpx;
  --radius-lg: 0rpx;
  --radius-xl: 0rpx;
  --radius-full: 0rpx;
}

.theme-stardew {
  --font-family-base: Georgia, 'Times New Roman', 'PingFang SC', serif;

  --primary-purple: #6b5ba7;
  --primary-yellow: #f4d27a;
  --primary-cyan: #75b7c9;
  --primary-orange: #d88b4d;
  --primary-green: #7ba05b;
  --primary-red: #c96b5d;

  --bg-dark: #f3e7c5;
  --bg-darker: #dfc99a;
  --bg-card: #fff8e7;
  --bg-card-light: #fffdf4;
  --bg-card-hover: #f6eedb;
  --bg-surface: #d6b98b;
  --bg-surface-dark: #c4a16c;
  --page-background-image:
    linear-gradient(180deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0)),
    radial-gradient(circle at 20% 20%, rgba(124, 170, 108, 0.18) 0, rgba(124, 170, 108, 0.18) 3rpx, transparent 3rpx),
    radial-gradient(circle at 70% 65%, rgba(214, 185, 139, 0.35) 0, rgba(214, 185, 139, 0.35) 4rpx, transparent 4rpx);

  --text-primary: #4e3620;
  --text-primary-light: #fff9ed;
  --text-secondary: #7b6041;
  --text-secondary-light: #f7e8c7;
  --text-muted: #9a866a;
  --text-dark: #3b2818;

  --status-trial: #75b7c9;
  --status-grinding: #d88b4d;
  --status-mastered: #7ba05b;
  --status-none: #8c7b6b;
  --status-trial-bg: rgba(117, 183, 201, 0.18);
  --status-grinding-bg: rgba(216, 139, 77, 0.18);
  --status-mastered-bg: rgba(123, 160, 91, 0.18);

  --accent-glow: #c96b5d;
  --accent-success: #7ba05b;
  --border-color: #6e4a2c;
  --border-light: #a77d51;
  --text-shadow-strong: none;
  --text-shadow-soft: none;

  --gradient-purple: #8475be;
  --gradient-yellow: #f4d27a;
  --gradient-cyan: #75b7c9;
  --gradient-card: #fff8e7;

  --shadow-sm: inset 2rpx 2rpx 0 0 rgba(255, 255, 255, 0.7), inset -3rpx -3rpx 0 0 rgba(110, 74, 44, 0.2);
  --shadow-md: inset 3rpx 3rpx 0 0 rgba(255, 255, 255, 0.75), inset -4rpx -4rpx 0 0 rgba(110, 74, 44, 0.22), 0 10rpx 18rpx rgba(110, 74, 44, 0.18);
  --shadow-lg: inset 4rpx 4rpx 0 0 rgba(255, 255, 255, 0.75), inset -5rpx -5rpx 0 0 rgba(110, 74, 44, 0.24), 0 16rpx 28rpx rgba(110, 74, 44, 0.2);
  --shadow-purple: 0 0 16rpx rgba(107, 91, 167, 0.28);
  --shadow-yellow: 0 0 16rpx rgba(244, 210, 122, 0.35);
  --shadow-cyan: 0 0 16rpx rgba(117, 183, 201, 0.28);
  --shadow-pressed: inset 3rpx 3rpx 0 0 rgba(110, 74, 44, 0.18), inset -2rpx -2rpx 0 0 rgba(255, 255, 255, 0.7);
  --shadow-text: none;
  --shadow-text-bold: none;
  --button-danger-highlight: #f0b8ac;
  --button-danger-shadow: #ab695b;
  --button-success-highlight: #b6d693;
  --button-success-shadow: #66874b;
  --button-neutral-highlight: #f7ecd7;
  --button-neutral-shadow: #9f7d56;
  --scene-sky-start: #c3ebff;
  --scene-sky-end: #f9efd6;
  --scene-ground-start: #97bf6e;
  --scene-ground-end: #749c4e;
  --scene-ground-border: #557439;
  --scene-soil-start: #d8b883;
  --scene-soil-end: #b88e5e;
  --scene-soil-border: #8f6840;
  --scene-card-accent: #c98a52;
  --scene-card-highlight: #e9bf8f;
  --scene-card-shadow: #9c6337;

  --radius-sm: 10rpx;
  --radius-md: 18rpx;
  --radius-lg: 26rpx;
  --radius-xl: 36rpx;
  --radius-full: 999rpx;
}

.theme-terraria {
  --font-family-base: 'Trebuchet MS', 'PingFang SC', sans-serif;

  --primary-purple: #9a6fd1;
  --primary-yellow: #f3d25b;
  --primary-cyan: #66c8d7;
  --primary-orange: #d88941;
  --primary-green: #61b05f;
  --primary-red: #d86a5f;

  --bg-dark: #1f2b1f;
  --bg-darker: #162016;
  --bg-card: #465a46;
  --bg-card-light: #567056;
  --bg-card-hover: #617c61;
  --bg-surface: #304330;
  --bg-surface-dark: #233223;
  --page-background-image:
    linear-gradient(180deg, rgba(130, 182, 102, 0.1), rgba(0, 0, 0, 0)),
    radial-gradient(circle at 18% 22%, rgba(132, 186, 118, 0.22) 0, rgba(132, 186, 118, 0.22) 3rpx, transparent 3rpx),
    radial-gradient(circle at 72% 68%, rgba(58, 90, 58, 0.42) 0, rgba(58, 90, 58, 0.42) 4rpx, transparent 4rpx);

  --text-primary: #eef5df;
  --text-primary-light: #f7ffe8;
  --text-secondary: #c2d2b8;
  --text-secondary-light: #dce9cf;
  --text-muted: #8fa18a;
  --text-dark: #102010;

  --status-trial: #66c8d7;
  --status-grinding: #d88941;
  --status-mastered: #61b05f;
  --status-none: #5f6d5f;
  --status-trial-bg: rgba(102, 200, 215, 0.2);
  --status-grinding-bg: rgba(216, 137, 65, 0.2);
  --status-mastered-bg: rgba(97, 176, 95, 0.2);

  --accent-glow: #c56d4d;
  --accent-success: #7bc66c;
  --border-color: #182518;
  --border-light: #6f8d63;
  --text-shadow-strong: 1rpx 2rpx 0 rgba(0, 0, 0, 0.35);
  --text-shadow-soft: 1rpx 1rpx 0 rgba(0, 0, 0, 0.25);

  --gradient-purple: #9a6fd1;
  --gradient-yellow: #f3d25b;
  --gradient-cyan: #66c8d7;
  --gradient-card: #465a46;

  --shadow-sm: inset 2rpx 2rpx 0 0 rgba(164, 201, 146, 0.35), inset -3rpx -3rpx 0 0 rgba(15, 25, 15, 0.3);
  --shadow-md: inset 3rpx 3rpx 0 0 rgba(164, 201, 146, 0.28), inset -4rpx -4rpx 0 0 rgba(15, 25, 15, 0.36), 0 8rpx 18rpx rgba(0, 0, 0, 0.24);
  --shadow-lg: inset 4rpx 4rpx 0 0 rgba(164, 201, 146, 0.25), inset -5rpx -5rpx 0 0 rgba(15, 25, 15, 0.4), 0 14rpx 28rpx rgba(0, 0, 0, 0.28);
  --shadow-purple: 0 0 16rpx rgba(154, 111, 209, 0.25);
  --shadow-yellow: 0 0 16rpx rgba(243, 210, 91, 0.3);
  --shadow-cyan: 0 0 16rpx rgba(102, 200, 215, 0.24);
  --shadow-pressed: inset 3rpx 3rpx 0 0 rgba(15, 25, 15, 0.3), inset -2rpx -2rpx 0 0 rgba(164, 201, 146, 0.18);
  --shadow-text: none;
  --shadow-text-bold: none;
  --button-danger-highlight: #e09a8f;
  --button-danger-shadow: #8e423c;
  --button-success-highlight: #8bcd79;
  --button-success-shadow: #366d38;
  --button-neutral-highlight: #7e9a72;
  --button-neutral-shadow: #253725;
  --scene-sky-start: #6fa7d6;
  --scene-sky-end: #bfe8ff;
  --scene-ground-start: #65ad54;
  --scene-ground-end: #4f8f42;
  --scene-ground-border: #355e2d;
  --scene-soil-start: #7c5a39;
  --scene-soil-end: #5d4028;
  --scene-soil-border: #402b1b;
  --scene-card-accent: #9d7f42;
  --scene-card-highlight: #d1b36c;
  --scene-card-shadow: #68542b;

  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 18rpx;
  --radius-xl: 26rpx;
  --radius-full: 999rpx;
}
