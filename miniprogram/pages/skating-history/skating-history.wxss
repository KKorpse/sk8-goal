/* 滑板历史页面样式 - 优化版 */

.history-page {
  min-height: 100vh;
  background: transparent;
  padding: var(--spacing-lg);
  padding-bottom: var(--safe-area-bottom-sm);
}

/* 顶部统计卡片 */
.summary-card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  box-shadow: var(--shadow-md);
}

.summary-header {
  margin-bottom: var(--spacing-lg);
}

.summary-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.summary-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.summary-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-value {
  font-size: var(--font-3xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
}

.summary-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: bold;
}

.summary-divider {
  width: 4rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-card);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.action-btn:active {
  box-shadow: var(--shadow-pressed);
  transform: scale(0.98);
}

.action-btn.start {
  background: var(--primary-orange);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffcc66, inset -4rpx -4rpx 0px 0px #aa6600;
}

.action-btn.pause {
  background: var(--primary-cyan);
  box-shadow: inset 4rpx 4rpx 0px 0px #66eeee, inset -4rpx -4rpx 0px 0px #008888;
}

.action-btn.start:active,
.action-btn.pause:active {
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.action-emoji {
  font-size: var(--icon-md);
}

.action-text {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary-light);
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 时间线区域 */
.timeline-section {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: var(--spacing-inner);
  box-shadow: var(--shadow-md);
}

.timeline-header {
  margin-bottom: var(--spacing-lg);
}

.timeline-title {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

/* 时间线节点 */
.timeline-node {
  display: flex;
  margin-bottom: var(--spacing-lg);
}

.timeline-node:last-child {
  margin-bottom: 0;
}

.node-line {
  width: 60rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
}

.node-line::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: var(--border-color);
}

.node-line.first::before {
  top: 24rpx;
}

.node-dot {
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid var(--border-color);
  background: var(--bg-card-light);
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  transition: all var(--transition-fast);
}

.node-dot.start {
  background: var(--primary-orange);
  box-shadow: 0 0 8rpx var(--primary-orange);
}

.node-dot.pause {
  background: var(--primary-cyan);
  box-shadow: 0 0 8rpx var(--primary-cyan);
}

.node-content {
  flex: 1;
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-pressed);
  transition: all var(--transition-fast);
}

.node-content:active {
  background: var(--bg-surface-dark);
}

.node-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.node-type {
  font-size: var(--font-sm);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.node-date {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: bold;
}

.node-duration {
  margin-bottom: 8rpx;
}

.duration-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.node-actions {
  display: flex;
  gap: var(--spacing-lg);
  margin-top: var(--spacing-md);
  padding-top: var(--spacing-md);
  border-top: 2rpx solid var(--border-color);
}

.node-action {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  padding: 8rpx var(--spacing-md);
  border: 2rpx solid var(--border-color);
  background: var(--bg-card);
  transition: all var(--transition-fast);
}

.node-action:active {
  box-shadow: inset 1rpx 1rpx 0px 0px #555555;
}

.node-action.delete {
  color: var(--status-grinding);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

.empty-emoji {
  font-size: 60rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: none;
  margin-bottom: var(--spacing-md);
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: bold;
}

/* 弹窗 - 优化版 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-normal);
  backdrop-filter: blur(8rpx);
}

.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background: var(--bg-card);
  border: 6rpx solid var(--border-color);
  box-shadow: 
    var(--shadow-lg),
    0 0 40rpx rgba(0, 0, 0, 0.5);
  animation: modalIn var(--transition-normal) ease-out;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  padding: var(--spacing-inner);
  border-bottom: 4rpx solid var(--border-color);
  background: var(--bg-surface);
}

.modal-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.modal-body {
  padding: var(--spacing-xl) var(--spacing-inner);
}

.date-picker-row {
  display: flex;
  align-items: center;
}

.picker-label {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: none;
}

.picker-value {
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  transition: all var(--transition-fast);
}

.picker-value:active {
  box-shadow: var(--shadow-pressed);
}

.modal-footer {
  display: flex;
  border-top: 4rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  padding: var(--spacing-lg);
  text-align: center;
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
  transition: all var(--transition-fast);
}

.modal-btn.cancel {
  border-right: 4rpx solid var(--border-color);
  background: var(--bg-surface);
}

.modal-btn.confirm {
  background: var(--primary-green);
}

.modal-btn:active {
  box-shadow: inset 2rpx 2rpx 0px 0px #555555;
  transform: scale(0.98);
}

/* 底部安全距离 */
.bottom-safe {
  height: var(--safe-area-bottom-sm);
}
