/* 滑板历史页面样式 - 优化版 */

.history-page {
  min-height: 100vh;
  background: transparent;
  padding: var(--spacing-lg);
  padding-bottom: var(--safe-area-bottom-sm);
}

/* 顶部统计卡片 */
.summary-card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  box-shadow: var(--shadow-md);
}

.summary-header {
  margin-bottom: var(--spacing-lg);
}

.summary-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.summary-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
}

.summary-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-value {
  font-size: var(--font-3xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
}

.summary-label {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: bold;
}

.summary-divider {
  width: 4rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  gap: var(--spacing-lg);
  margin-bottom: var(--spacing-card);
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  padding: var(--spacing-lg);
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.action-btn:active {
  box-shadow: var(--shadow-pressed);
  transform: scale(0.98);
}

.action-btn.start {
  background: var(--primary-orange);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffcc66, inset -4rpx -4rpx 0px 0px #aa6600;
}

.action-btn.pause {
  background: var(--primary-cyan);
  box-shadow: inset 4rpx 4rpx 0px 0px #66eeee, inset -4rpx -4rpx 0px 0px #008888;
}

.action-btn.start:active,
.action-btn.pause:active {
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.action-emoji {
  font-size: var(--icon-md);
}

.action-text {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary-light);
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 时间线区域 */
.timeline-section {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: var(--spacing-inner);
  box-shadow: var(--shadow-md);
}

.timeline-header {
  margin-bottom: var(--spacing-lg);
}

.timeline-title {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

/* 区间展示列表 */
.periods-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-card);
}

.period-item {
  display: flex;
  gap: var(--spacing-lg);
}

.period-timeline {
  width: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.timeline-bar {
  flex: 1;
  width: 8rpx;
  border-radius: 4rpx;
  min-height: 100rpx;
}

.timeline-bar.skating {
  background: linear-gradient(180deg, var(--primary-orange) 0%, var(--primary-yellow) 100%);
  box-shadow: 0 0 8rpx rgba(255, 170, 0, 0.5);
}

.timeline-bar.pause {
  background: linear-gradient(180deg, var(--primary-cyan) 0%, #008888 100%);
}

/* 区间内容 */
.period-content {
  flex: 1;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-pressed);
  padding: var(--spacing-lg);
  transition: all var(--transition-fast);
}

.period-content:active {
  background: var(--bg-surface-dark);
}

.period-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.period-badge {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx var(--spacing-md);
  border: 2rpx solid var(--border-color);
  background: var(--bg-card);
}

.period-badge.skating {
  background: rgba(255, 170, 0, 0.2);
  border-color: var(--primary-orange);
}

.period-badge.pause {
  background: rgba(0, 170, 170, 0.2);
  border-color: var(--primary-cyan);
}

.badge-icon {
  font-size: var(--font-base);
}

.badge-text {
  font-size: var(--font-sm);
  font-weight: bold;
  color: var(--text-primary);
}

.period-duration {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 1rpx 1rpx 0 #000;
}

/* 编辑按钮 */
.period-edit-btn {
  padding: 8rpx 12rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.period-edit-btn:active {
  box-shadow: var(--shadow-pressed);
  transform: scale(0.95);
}

.edit-icon {
  font-size: var(--font-base);
}

/* 时间区间展示 */
.period-time-range {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  margin-bottom: var(--spacing-lg);
  padding: var(--spacing-md);
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
}

.time-point {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 120rpx;
}

.time-point.start {
  align-items: flex-start;
}

.time-point.end {
  align-items: flex-end;
}

.time-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-bottom: 4rpx;
}

.time-value {
  font-size: var(--font-sm);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.time-arrow {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 8rpx;
  justify-content: center;
}

.arrow-line {
  flex: 1;
  height: 2rpx;
  background: var(--border-color);
}

.arrow-days {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  white-space: nowrap;
  padding: 4rpx 12rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
}

/* 区间操作按钮 */
.period-actions {
  display: flex;
  gap: var(--spacing-lg);
  padding-top: var(--spacing-md);
  border-top: 2rpx solid var(--border-color);
}

.period-action {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  padding: 8rpx var(--spacing-md);
  border: 2rpx solid var(--border-color);
  background: var(--bg-card);
  transition: all var(--transition-fast);
}

.period-action:active {
  box-shadow: inset 1rpx 1rpx 0px 0px #555555;
}

.period-action.delete {
  color: var(--status-grinding);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

.empty-emoji {
  font-size: 60rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-text {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: none;
  margin-bottom: var(--spacing-md);
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: bold;
}

/* 弹窗 - 优化版 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-normal);
  backdrop-filter: blur(8rpx);
}

.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-content {
  width: 80%;
  max-width: 600rpx;
  background: var(--bg-card);
  border: 6rpx solid var(--border-color);
  box-shadow: 
    var(--shadow-lg),
    0 0 40rpx rgba(0, 0, 0, 0.5);
  animation: modalIn var(--transition-normal) ease-out;
}

@keyframes modalIn {
  from {
    opacity: 0;
    transform: scale(0.9) translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.modal-header {
  padding: var(--spacing-inner);
  border-bottom: 4rpx solid var(--border-color);
  background: var(--bg-surface);
}

.modal-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.modal-body {
  padding: var(--spacing-xl) var(--spacing-inner);
}

.date-picker-row {
  display: flex;
  align-items: center;
}

.picker-label {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: none;
}

.picker-value {
  padding: var(--spacing-md) var(--spacing-lg);
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  transition: all var(--transition-fast);
}

.picker-value:active {
  box-shadow: var(--shadow-pressed);
}

.date-range-hint {
  margin-top: var(--spacing-lg);
  padding: var(--spacing-md);
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
}

.hint-text {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.modal-footer {
  display: flex;
  border-top: 4rpx solid var(--border-color);
}

.modal-btn {
  flex: 1;
  padding: var(--spacing-lg);
  text-align: center;
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
  transition: all var(--transition-fast);
}

.modal-btn.cancel {
  border-right: 4rpx solid var(--border-color);
  background: var(--bg-surface);
}

.modal-btn.confirm {
  background: var(--primary-green);
}

.modal-btn:active {
  box-shadow: inset 2rpx 2rpx 0px 0px #555555;
  transform: scale(0.98);
}

/* 底部安全距离 */
.bottom-safe {
  height: var(--safe-area-bottom-sm);
}

/* 操作菜单弹窗 */
.action-menu-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 1001;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--transition-normal);
  backdrop-filter: blur(8rpx);
}

.action-menu-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.action-menu-content {
  width: 100%;
  background: var(--bg-card);
  border-top: 6rpx solid var(--border-color);
  padding-bottom: var(--safe-area-bottom);
  animation: slideUp var(--transition-normal) ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.action-menu-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
  padding: var(--spacing-lg) var(--spacing-xl);
  border-bottom: 2rpx solid var(--border-color);
  transition: all var(--transition-fast);
}

.action-menu-item:active {
  background: var(--bg-surface);
}

.action-menu-item.delete {
  color: var(--status-grinding);
}

.menu-icon {
  font-size: var(--icon-sm);
}

.menu-text {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
}

.action-menu-item.delete .menu-text {
  color: var(--status-grinding);
}

.action-menu-cancel {
  padding: var(--spacing-xl);
  text-align: center;
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-secondary);
  background: var(--bg-surface);
  margin-top: var(--spacing-md);
}
