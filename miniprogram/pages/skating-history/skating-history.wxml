<!--滑板历史页面-->
<view class="history-page theme-shell {{themeClass}}">
  <!-- 顶部统计 -->
  <view class="summary-card">
    <view class="summary-header">
      <text class="summary-title">📅 滑板历程</text>
    </view>
    <view class="summary-content">
      <view class="summary-item">
        <text class="summary-value">{{yearsSkating}}</text>
        <text class="summary-label">年</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-value">{{periods.length}}</text>
        <text class="summary-label">个阶段</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮（单一切换按钮） -->
  <view class="action-bar">
    <view class="action-btn {{actionType}}" bindtap="toggleSkating">
      <text class="action-emoji">{{actionType === 'start' ? '▶️' : '⏸️'}}</text>
      <text class="action-text">{{actionType === 'start' ? '开始滑板' : '暂停滑板'}}</text>
    </view>
  </view>

  <!-- 时间线 -->
  <view class="timeline-section">
    <view class="timeline-header">
      <text class="timeline-title">时间线</text>
    </view>

    <!-- 区间展示模式 -->
    <view class="periods-list" wx:if="{{periods.length > 0}}">
      <view class="period-item {{item.type}}" wx:for="{{periods}}" wx:key="id">
        <!-- 时间轴线条 -->
        <view class="period-timeline">
          <view class="timeline-bar {{item.type}}"></view>
        </view>
        
        <!-- 区间内容 -->
        <view class="period-content">
          <!-- 区间标题 -->
          <view class="period-header">
            <view class="period-badge {{item.type}}">
              <text class="badge-icon">{{item.type === 'skating' ? '🛹' : '💤'}}</text>
              <text class="badge-text">{{item.type === 'skating' ? '滑板中' : '暂停中'}}</text>
            </view>
            <text class="period-duration">{{item.durationText}}</text>
            <!-- 编辑按钮 -->
            <view class="period-edit-btn" catchtap="showPeriodMenu" data-id="{{item.startId}}" data-end-id="{{item.endId}}" data-type="{{item.type}}">
              <text class="edit-icon">🖊️</text>
            </view>
          </view>
          
          <!-- 时间区间 -->
          <view class="period-time-range">
            <view class="time-point start">
              <text class="time-label">{{item.type === 'skating' ? '开始' : '暂停'}}</text>
              <text class="time-value">{{item.startDate}}</text>
            </view>
            <view class="time-arrow">
              <view class="arrow-line"></view>
              <text class="arrow-days">{{item.days}}天</text>
              <view class="arrow-line"></view>
            </view>
            <view class="time-point end">
              <text class="time-label">{{item.isCurrent ? '至今' : (item.type === 'skating' ? '暂停' : '恢复')}}</text>
              <text class="time-value">{{item.endDate}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{periods.length === 0}}">
      <text class="empty-emoji">🛹</text>
      <text class="empty-text">还没有滑板记录</text>
      <text class="empty-hint">点击上方按钮添加你的滑板历程</text>
    </view>
  </view>

  <!-- 底部安全距离 -->
  <view class="bottom-safe"></view>
</view>

<!-- 日期选择弹窗 -->
<view class="modal-mask {{showModal ? 'show' : ''}}" bindtap="closeModal" wx:if="{{showModal}}">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">{{editingNode ? '编辑节点' : (actionType === 'start' ? '开始滑板' : '暂停滑板')}}</text>
    </view>
    <view class="modal-body">
      <view class="date-picker-row">
        <text class="picker-label">日期：</text>
        <picker mode="date" value="{{selectedDate}}" start="{{dateRangeStart}}" end="{{dateRangeEnd}}" bindchange="onDateChange">
          <view class="picker-value">{{selectedDate}}</view>
        </picker>
      </view>
      <view class="date-range-hint" wx:if="{{editingNode}}">
        <text class="hint-text">📅 可选范围: {{dateRangeStart}} ~ {{dateRangeEnd}}</text>
      </view>
    </view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="closeModal">取消</view>
      <view class="modal-btn confirm" bindtap="confirmNode">确定</view>
    </view>
  </view>
</view>

<!-- 操作菜单弹窗 -->
<view class="action-menu-mask {{showActionMenu ? 'show' : ''}}" bindtap="closeActionMenu" wx:if="{{showActionMenu}}">
  <view class="action-menu-content" catchtap="preventClose">
    <view class="action-menu-item" bindtap="editPeriod">
      <text class="menu-icon">✏️</text>
      <text class="menu-text">编辑</text>
    </view>
    <view class="action-menu-item delete" bindtap="deletePeriod">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">删除</text>
    </view>
    <view class="action-menu-cancel" bindtap="closeActionMenu">取消</view>
  </view>
</view>
