/* 我的页面样式 */

.profile-page {
  min-height: 100vh;
  background: var(--bg-dark);
  padding: 20rpx;
}

/* 个人信息卡片 */
.profile-card {
  background: linear-gradient(180deg, var(--bg-card) 0%, var(--bg-surface) 100%);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid var(--primary-purple);
  background: var(--bg-card-light);
}

.avatar-glow {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border-radius: 50%;
  box-shadow: 0 0 20rpx var(--primary-purple);
  opacity: 0.5;
  pointer-events: none;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 标签 */
.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: var(--bg-card-light);
  border-radius: 999rpx;
}

.tag-icon {
  font-size: 22rpx;
}

.tag-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 头衔 */
.title-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: rgba(251, 191, 36, 0.1);
  border-radius: 16rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.3);
}

.title-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-emoji {
  font-size: 32rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-yellow);
}

.title-arrow {
  font-size: 32rpx;
  color: var(--text-muted);
}

/* 统计卡片 */
.stats-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.stats-content {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item.main {
  flex: 1.5;
}

.stat-number {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--primary-yellow);
  line-height: 1.2;
}

.stat-number.small {
  font-size: 36rpx;
}

.stat-number.mastered {
  color: var(--status-mastered);
}

.stat-number.trial {
  color: var(--status-trial);
}

.stat-number.grinding {
  color: var(--status-grinding);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 进度条 */
.progress-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: var(--bg-card-light);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-purple), var(--primary-yellow));
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 60rpx;
  text-align: right;
}

/* 时光轴卡片 */
.timeline-card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
}

.timeline-header {
  margin-bottom: 24rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.timeline-list {
  /* 样式由组件控制 */
}

/* 时光轴空状态 */
.timeline-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.timeline-empty .empty-emoji {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.timeline-empty .empty-text {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
}

.timeline-empty .empty-hint {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 20rpx;
  color: var(--text-muted);
  opacity: 0.6;
}

/* 底部安全距离 */
.bottom-safe {
  height: calc(80rpx + env(safe-area-inset-bottom));
}
