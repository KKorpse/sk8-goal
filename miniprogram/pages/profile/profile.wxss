/* 我的页面样式 - 优化版 */

.profile-page {
  min-height: 100vh;
  background: transparent;
  padding: var(--spacing-lg);
  padding-bottom: var(--safe-area-bottom);
}

/* 个人信息卡片 */
.profile-card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  box-shadow: var(--shadow-md);
  transition: box-shadow var(--transition-fast);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: var(--spacing-lg);
}

.avatar-wrapper {
  position: relative;
  margin-right: var(--spacing-lg);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 0;
  border: 4rpx solid var(--border-color);
  background: var(--bg-card-light);
  box-shadow: var(--shadow-sm);
}

/* 头像编辑提示 */
.avatar-edit-hint {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background: var(--primary-cyan);
  border: 3rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 2rpx 2rpx 0px 0px #66eeee;
}

.edit-icon {
  font-size: 20rpx;
}

/* MC 史蒂夫风格头像 - 像素风格 */
.avatar-steve {
  width: 120rpx;
  height: 120rpx;
  border: 4rpx solid var(--border-color);
  background: var(--bg-card-light);
  box-shadow: var(--shadow-sm);
  position: relative;
  overflow: hidden;
  image-rendering: pixelated;
}

/* 史蒂夫头部像素绘制 */
.avatar-steve::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: 
    /* 头发 - 第一行 */
    linear-gradient(to right, #5a3d2b 0, #5a3d2b 14.28%, #5a3d2b 14.28%, #5a3d2b 28.57%, #5a3d2b 28.57%, #5a3d2b 42.85%, #5a3d2b 42.85%, #5a3d2b 57.14%, #5a3d2b 57.14%, #5a3d2b 71.42%, #5a3d2b 71.42%, #5a3d2b 85.71%, #5a3d2b 85.71%, #5a3d2b 100%) 0 0 / 100% 14.28% no-repeat,
    /* 头发 - 第二行 */
    linear-gradient(to right, #5a3d2b 0, #5a3d2b 14.28%, #5a3d2b 14.28%, #5a3d2b 28.57%, #5a3d2b 28.57%, #5a3d2b 42.85%, #5a3d2b 42.85%, #5a3d2b 57.14%, #5a3d2b 57.14%, #5a3d2b 71.42%, #5a3d2b 71.42%, #5a3d2b 85.71%, #5a3d2b 85.71%, #5a3d2b 100%) 0 14.28% / 100% 14.28% no-repeat,
    /* 额头 */
    linear-gradient(to right, #c4a87c 0, #c4a87c 14.28%, #c4a87c 14.28%, #c4a87c 28.57%, #c4a87c 28.57%, #c4a87c 42.85%, #c4a87c 42.85%, #c4a87c 57.14%, #c4a87c 57.14%, #c4a87c 71.42%, #c4a87c 71.42%, #c4a87c 85.71%, #c4a87c 85.71%, #c4a87c 100%) 0 28.57% / 100% 14.28% no-repeat,
    /* 眼睛行 */
    linear-gradient(to right, #c4a87c 0, #c4a87c 14.28%, #fff 14.28%, #fff 28.57%, #3d5a80 28.57%, #3d5a80 42.85%, #c4a87c 42.85%, #c4a87c 57.14%, #fff 57.14%, #fff 71.42%, #3d5a80 71.42%, #3d5a80 85.71%, #c4a87c 85.71%, #c4a87c 100%) 0 42.85% / 100% 14.28% no-repeat,
    /* 鼻子行 */
    linear-gradient(to right, #c4a87c 0, #c4a87c 14.28%, #c4a87c 14.28%, #c4a87c 28.57%, #a08050 28.57%, #a08050 42.85%, #c4a87c 42.85%, #c4a87c 57.14%, #c4a87c 57.14%, #c4a87c 71.42%, #a08050 71.42%, #a08050 85.71%, #c4a87c 85.71%, #c4a87c 100%) 0 57.14% / 100% 14.28% no-repeat,
    /* 嘴巴行 */
    linear-gradient(to right, #c4a87c 0, #c4a87c 14.28%, #c4a87c 14.28%, #c4a87c 28.57%, #8b6c4a 28.57%, #8b6c4a 42.85%, #c4a87c 42.85%, #c4a87c 57.14%, #c4a87c 57.14%, #c4a87c 71.42%, #8b6c4a 71.42%, #8b6c4a 85.71%, #c4a87c 85.71%, #c4a87c 100%) 0 71.42% / 100% 14.28% no-repeat,
    /* 下巴 */
    linear-gradient(to right, #c4a87c 0, #c4a87c 14.28%, #c4a87c 14.28%, #c4a87c 28.57%, #c4a87c 28.57%, #c4a87c 42.85%, #c4a87c 42.85%, #c4a87c 57.14%, #c4a87c 57.14%, #c4a87c 71.42%, #c4a87c 71.42%, #c4a87c 85.71%, #c4a87c 85.71%, #c4a87c 100%) 0 85.71% / 100% 14.28% no-repeat;
}

.user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.nickname {
  font-size: var(--font-2xl);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
  margin-bottom: 8rpx;
}

.nickname-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}

.nickname-edit-icon {
  font-size: var(--font-sm);
  opacity: 0.6;
}

.user-id {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: bold;
}

/* 右侧信息区 */
.header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: var(--spacing-sm);
  margin-left: var(--spacing-md);
}

.header-tag {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  background: var(--bg-surface);
  border: 3rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
  min-width: 150rpx;
}

.header-tag:active {
  background: var(--bg-card);
  box-shadow: var(--shadow-pressed);
}

.header-tag-text {
  font-size: var(--font-xs);
  color: var(--text-primary-light);
  font-weight: bold;
  text-shadow: none;
}

.tag-arrow {
  font-size: 20rpx;
  color: var(--text-secondary-light);
  margin-left: 4rpx;
  transition: transform var(--transition-normal);
}

.tag-arrow.expanded {
  transform: rotate(180deg);
}

/* 脚位设置面板 */
.stance-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--transition-normal);
  margin-bottom: 0;
}

.stance-panel.show {
  max-height: 240rpx;
  margin-bottom: var(--spacing-lg);
}

.stance-option {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) 20rpx;
  margin-top: var(--spacing-md);
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.stance-option.active {
  background: var(--primary-green);
  border-color: var(--border-color);
}

.stance-option:active {
  box-shadow: var(--shadow-pressed);
}

.stance-emoji {
  font-size: var(--font-base);
  margin-right: var(--spacing-md);
}

.stance-name {
  flex: 1;
  font-size: var(--font-sm);
  color: var(--text-primary-light);
  font-weight: bold;
  text-shadow: none;
}

.stance-check {
  font-size: var(--font-base);
  color: var(--primary-yellow);
  font-weight: bold;
}

/* 成就徽章 */
.badges-wrapper {
  padding: var(--spacing-lg) var(--spacing-inner);
  background: var(--bg-surface);
  border-radius: 0;
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-pressed);
}

.badges-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.badges-title {
  font-size: var(--font-sm);
  font-weight: bold;
  color: var(--text-primary-light);
  text-shadow: none;
}

.badges-count {
  font-size: var(--font-xs);
  color: var(--text-secondary-light);
  font-weight: bold;
}

.badges-list {
  display: flex;
  flex-wrap: nowrap;
  gap: var(--spacing-md);
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
}

.badges-list::-webkit-scrollbar {
  display: none;
}

.badge-item {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
  position: relative;
}

.badge-item.locked {
  background: var(--bg-surface-dark);
}

.badge-item.locked .badge-emoji {
  opacity: 0.4;
  filter: grayscale(1);
}

.badge-item.badge-more {
  background: var(--bg-surface);
}

.badge-more-text {
  font-size: var(--font-xs);
  font-weight: bold;
  color: var(--text-primary);
}

.badge-emoji {
  font-size: var(--icon-md);
}

/* 统计卡片 */
.stats-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-md);
}

.stats-header {
  margin-bottom: var(--spacing-lg);
}

.stats-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

/* 统计汇总布局 - 分割线风格 */
.stats-summary {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.summary-item.stat-clickable {
  cursor: pointer;
}

.summary-item.stat-clickable:active {
  opacity: 0.7;
}

.summary-num {
  font-size: var(--font-xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
  font-variant-numeric: tabular-nums;
  line-height: 1.2;
}

.summary-label {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

.summary-divider {
  width: 4rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 不同状态的颜色 */
.summary-item.mastered .summary-num {
  color: var(--primary-green);
}

.summary-item.trial .summary-num {
  color: var(--primary-cyan);
}

.summary-item.grinding .summary-num {
  color: var(--primary-orange);
}

/* 合并进度卡片: Ollie + 统计 */
.progress-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-md);
}

.progress-ollie {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.progress-ollie-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.progress-ollie-title {
  font-size: 20rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

.progress-ollie-values {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
}

.progress-ollie-main {
  font-size: var(--font-xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
  font-variant-numeric: tabular-nums;
}

.progress-ollie-sep {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.progress-ollie-sub {
  font-size: 24rpx;
  color: var(--primary-cyan);
  font-weight: bold;
  font-variant-numeric: tabular-nums;
}

.progress-ollie-unit {
  font-size: 20rpx;
  color: var(--text-secondary);
  margin-left: 4rpx;
}

.progress-ollie-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
  flex: 1;
  margin-left: 24rpx;
}

.progress-ollie-bar {
  width: 120rpx;
  height: 12rpx;
  background: rgba(255,255,255,0.1);
  border: 2rpx solid var(--border-color);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-ollie-fill {
  height: 100%;
  background: var(--primary-yellow);
  transition: width 0.3s;
}

.progress-ollie-fill-switch {
  background: var(--primary-cyan);
}

.progress-ollie-label {
  font-size: 16rpx;
  color: var(--text-secondary);
  width: 120rpx;
  text-align: center;
}

.progress-expand-arrow {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 16rpx;
  transition: transform 0.2s;
}

.progress-expand-arrow.expanded {
  transform: rotate(180deg);
}

.progress-divider {
  height: 4rpx;
  background: var(--border-color);
  margin: var(--spacing-lg) 0;
}

/* Ollie 卡片 */
.ollie-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-md);
  overflow: hidden;
}

/* Ollie 展示行 */
.ollie-display {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.ollie-main {
  display: flex;
  align-items: baseline;
  gap: var(--spacing-md);
}

.ollie-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.ollie-values {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.ollie-value-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.ollie-value-label {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  padding: 2rpx 8rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
  margin-right: 4rpx;
}

.ollie-value-divider {
  font-size: var(--font-lg);
  color: var(--text-secondary);
  margin: 0 4rpx;
}

.ollie-val-main {
  font-size: var(--font-2xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
  font-variant-numeric: tabular-nums;
  min-width: 48rpx;
  text-align: right;
  display: inline-block;
}

.ollie-val-sub {
  font-size: var(--font-base);
  color: var(--text-secondary);
  font-weight: bold;
  font-variant-numeric: tabular-nums;
  min-width: 48rpx;
  text-align: right;
  display: inline-block;
}

.ollie-unit {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.ollie-expand-arrow {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  transition: transform var(--transition-normal);
}

.ollie-expand-arrow.expanded {
  transform: rotate(180deg);
}

/* Ollie 设置面板 */
.ollie-settings {
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--transition-normal);
}

.ollie-settings.show {
  max-height: 320rpx;
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-lg);
  border-top: 4rpx solid var(--border-color);
}

.ollie-setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ollie-label {
  font-size: var(--font-base);
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: none;
}

.ollie-label-wrapper {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.ollie-label-icon {
  font-size: var(--font-base);
}

.ollie-control {
  display: flex;
  align-items: center;
  gap: var(--spacing-lg);
}

.ollie-btn {
  width: 64rpx;
  height: 64rpx;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--font-xl);
  font-weight: bold;
  color: var(--text-primary);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.ollie-btn:active {
  background: var(--bg-card);
  box-shadow: var(--shadow-pressed);
}

.ollie-value {
  font-size: var(--font-2xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
  min-width: 64rpx;
  text-align: center;
}

.ollie-divider {
  height: 4rpx;
  background: var(--border-color);
  margin: var(--spacing-md) 0;
}

/* 解锁新招按钮 */
.action-card {
  background: var(--bg-surface);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  transition: all var(--transition-fast);
}

.action-card:active {
  background: var(--bg-card);
  box-shadow: var(--shadow-pressed);
}

.action-emoji {
  font-size: var(--icon-lg);
  margin-right: var(--spacing-md);
}

.action-text {
  flex: 1;
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
}

.action-arrow {
  font-size: var(--icon-lg);
  color: var(--text-primary);
  font-weight: bold;
}
/* 成就时光轴列表 */
.timeline-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.achievement-item {
  display: flex;
  align-items: flex-start;
  gap: var(--spacing-md);
}

.achievement-dot {
  width: 18rpx;
  height: 18rpx;
  background: var(--primary-yellow);
  border: 4rpx solid var(--border-color);
  margin-top: 8rpx;
  flex-shrink: 0;
}

.achievement-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding-bottom: var(--spacing-md);
  border-bottom: 4rpx solid var(--border-color);
}

.achievement-item:last-child .achievement-content {
  border-bottom: none;
}

.achievement-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.achievement-emoji {
  font-size: var(--font-base);
}

.achievement-name {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.achievement-date {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.timeline-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-md);
}

.timeline-header {
  margin-bottom: var(--spacing-lg);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.timeline-title {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

/* 解锁新招按钮（小号） */
.unlock-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: var(--spacing-md) 20rpx;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.unlock-btn:active {
  background: var(--bg-card);
  box-shadow: var(--shadow-pressed);
}

.unlock-icon {
  font-size: var(--font-sm);
}

.unlock-text {
  font-size: var(--font-sm);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
}

.unlock-arrow {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: bold;
}

/* 横屏游戏场景 */
.game-scene {
  position: relative;
  height: 320rpx;
  background: linear-gradient(180deg, #5c94fc 0%, #87ceeb 60%, #87ceeb 100%);
  border: 4rpx solid var(--border-color);
  overflow: hidden;
  margin-top: var(--spacing-lg);
}

/* 天空背景 */
.sky-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  pointer-events: none;
}

/* 飘动的云朵 */
.cloud {
  position: absolute;
  font-size: 32rpx;
  opacity: 0.9;
  animation: floatCloud linear infinite;
}

.cloud-1 {
  top: 20rpx;
  animation-duration: 20s;
}

.cloud-2 {
  top: 60rpx;
  font-size: 24rpx;
  animation-duration: 25s;
  animation-delay: -10s;
}

.cloud-3 {
  top: 100rpx;
  font-size: 28rpx;
  animation-duration: 30s;
  animation-delay: -5s;
}

@keyframes floatCloud {
  0% { left: -60rpx; }
  100% { left: calc(100% + 60rpx); }
}

/* 游戏滚动区域 */
.game-scroll {
  position: absolute;
  top: 40rpx;
  left: 0;
  right: 0;
  bottom: 80rpx;
  white-space: nowrap;
}

.game-track {
  display: inline-flex;
  align-items: flex-end;
  padding: 0 20rpx;
  gap: 16rpx;
  height: 100%;
}

/* 起点 */
.track-start {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  width: 60rpx;
  height: 140rpx;
}

.start-flag {
  font-size: 40rpx;
  animation: wave 1s ease-in-out infinite;
}

@keyframes wave {
  0%, 100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}

.start-label {
  font-size: 18rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 1rpx 1rpx 0 #000;
  margin-top: 4rpx;
}

/* 招式砖块 - 问号砖块风格 */
.trick-block {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 120rpx;
  cursor: pointer;
  transition: transform var(--transition-fast);
  position: relative;
}

.trick-block:active {
  transform: scale(0.95) translateY(4rpx);
}

.block-body {
  width: 80rpx;
  height: 80rpx;
  background: #e89b3c;
  border: 4rpx solid #000;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: inset 4rpx 4rpx 0 #f0b860, inset -4rpx -4rpx 0 #a06020;
  animation: blockFloat 2s ease-in-out infinite;
}

.trick-block:nth-child(odd) .block-body {
  animation-delay: 0.5s;
}

@keyframes blockFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.trick-block:active .block-body {
  animation: none;
  box-shadow: inset -4rpx -4rpx 0 #f0b860, inset 4rpx 4rpx 0 #a06020;
}

.block-shine {
  position: absolute;
  top: 6rpx;
  left: 6rpx;
  width: 16rpx;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.4);
}

.block-emoji {
  font-size: 32rpx;
  position: relative;
  z-index: 1;
}

/* 状态标识 */
.block-status {
  position: absolute;
  top: -16rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #000;
}

.block-status.mastered {
  background: var(--primary-green);
  box-shadow: 0 0 8rpx var(--primary-green);
}

.block-status.trial {
  background: var(--primary-cyan);
  box-shadow: 0 0 8rpx var(--primary-cyan);
}

.block-status.grinding {
  background: var(--primary-orange);
  box-shadow: 0 0 8rpx var(--primary-orange);
}

.status-star {
  font-size: 16rpx;
}

/* 招式名 */
.block-name {
  font-size: 18rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 1rpx 1rpx 0 #000;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 116rpx;
  margin-top: 4rpx;
}

/* 脚位标签 */
.block-stance {
  font-size: 14rpx;
  font-weight: bold;
  color: #fff;
  background: rgba(0, 0, 0, 0.5);
  padding: 2rpx 8rpx;
  margin-top: 4rpx;
}

/* 终点 */
.track-end {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  flex-shrink: 0;
  width: 80rpx;
  height: 140rpx;
}

.end-castle {
  font-size: 48rpx;
  animation: castleGlow 2s ease-in-out infinite;
}

@keyframes castleGlow {
  0%, 100% { filter: brightness(1); }
  50% { filter: brightness(1.2); }
}

.end-label {
  font-size: 16rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 1rpx 1rpx 0 #000;
  margin-top: 4rpx;
}

/* 地面 */
.ground {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 80rpx;
  pointer-events: none;
}

.grass {
  height: 20rpx;
  background: repeating-linear-gradient(
    90deg,
    #5cb85c 0px,
    #5cb85c 8rpx,
    #4a9f4a 8rpx,
    #4a9f4a 16rpx
  );
}

.dirt {
  height: 60rpx;
  background: repeating-linear-gradient(
    90deg,
    #8b5a2b 0px,
    #8b5a2b 8rpx,
    #6b4423 8rpx,
    #6b4423 16rpx
  );
}

/* 滑板小人 */
.skater {
  position: absolute;
  bottom: 84rpx;
  left: 24rpx;
  z-index: 10;
  animation: skaterMove 3s ease-in-out infinite;
}

.skater-emoji {
  font-size: 36rpx;
  transform: scaleX(-1);
}

@keyframes skaterMove {
  0%, 100% { transform: translateX(0) rotate(0deg); }
  25% { transform: translateX(8rpx) rotate(5deg); }
  50% { transform: translateX(0) rotate(0deg); }
  75% { transform: translateX(-4rpx) rotate(-3deg); }
}

/* 时光轴空状态 */
.timeline-empty {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl) 0;
  min-height: 200rpx;
  background: linear-gradient(180deg, #5c94fc 0%, #87ceeb 100%);
  border: 4rpx solid var(--border-color);
  overflow: hidden;
  margin-top: var(--spacing-lg);
}

.empty-game-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  pointer-events: none;
}

.empty-game-bg .cloud {
  animation-duration: 15s;
}

.timeline-empty .empty-emoji {
  font-size: 60rpx;
  margin-bottom: var(--spacing-lg);
  position: relative;
  z-index: 1;
}

.timeline-empty .empty-text {
  font-size: var(--font-base);
  color: #fff;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
  margin-bottom: var(--spacing-md);
  position: relative;
  z-index: 1;
}

.timeline-empty .empty-hint {
  font-size: var(--font-sm);
  color: #fff;
  font-weight: bold;
  text-shadow: 1rpx 1rpx 0 #000;
  position: relative;
  z-index: 1;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
}

.footer-text {
  font-size: var(--font-sm);
  color: var(--text-primary-light);
  text-shadow: 2rpx 2rpx 0 #000;
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 18rpx;
  color: var(--text-secondary-light);
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 底部安全距离 */
.bottom-safe {
  height: var(--safe-area-bottom);
}

/* ========== 徽章详情弹窗 - 优化版 ========== */
.badge-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.75);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
