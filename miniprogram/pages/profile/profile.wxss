/* 我的页面样式 */

.profile-page {
  min-height: 100vh;
  background: transparent;
  padding: 20rpx;
}

/* 个人信息卡片 */
.profile-card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar-wrapper {
  position: relative;
  margin-right: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 0;
  border: 4rpx solid var(--border-color);
  background: var(--bg-card-light);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.avatar-glow {
  display: none;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: var(--shadow-text);
  margin-bottom: 8rpx;
}

.user-id {
  font-size: 24rpx;
  color: var(--text-dark);
  font-weight: bold;
}

/* 标签 */
.user-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.tag {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: var(--bg-surface);
  border-radius: 0;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 2rpx 2rpx 0px 0px #ffffff, inset -2rpx -2rpx 0px 0px #555555;
}

.tag-icon {
  font-size: 22rpx;
}

.tag-text {
  font-size: 24rpx;
  color: var(--text-primary);
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 头衔 */
.title-wrapper {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: var(--bg-surface);
  border-radius: 0;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.title-badge {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-emoji {
  font-size: 32rpx;
}

.title-text {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: var(--shadow-text-bold);
}

.title-arrow {
  font-size: 32rpx;
  color: var(--text-primary);
  font-weight: bold;
}

/* 统计卡片 */
.stats-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.stats-header {
  margin-bottom: 24rpx;
}

.stats-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: var(--shadow-text-bold);
}

.stats-content {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-item.main {
  flex: 1.5;
}

.stat-number {
  font-size: 56rpx;
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: var(--shadow-text);
  line-height: 1.2;
}

.stat-number.small {
  font-size: 36rpx;
}

.stat-number.mastered {
  color: var(--status-mastered);
}

.stat-number.trial {
  color: var(--status-trial);
}

.stat-number.grinding {
  color: var(--status-grinding);
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-dark);
  font-weight: bold;
  margin-top: 8rpx;
}

.stat-divider {
  width: 4rpx;
  height: 60rpx;
  background: var(--border-color);
}

/* 进度条 */
.progress-wrapper {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progress-bar {
  flex: 1;
  height: 24rpx;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  overflow: hidden;
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.progress-fill {
  height: 100%;
  background: var(--primary-green);
  border-radius: 0;
  border-right: 4rpx solid var(--border-color);
}

.progress-text {
  font-size: 24rpx;
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
  min-width: 60rpx;
  text-align: right;
}

/* Ollie 卡片 */
.ollie-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.ollie-header {
  margin-bottom: 24rpx;
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.ollie-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: var(--shadow-text-bold);
}

.ollie-unit {
  font-size: 22rpx;
  color: var(--text-dark);
}

.ollie-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.ollie-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.ollie-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: var(--shadow-text-bold);
}

.ollie-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.ollie-btn {
  width: 60rpx;
  height: 60rpx;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--text-primary);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.ollie-btn:active {
  background: var(--bg-card);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.ollie-value {
  font-size: 40rpx;
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: var(--shadow-text-bold);
  min-width: 60rpx;
  text-align: center;
}

.ollie-divider {
  height: 4rpx;
  background: var(--border-color);
}

/* 解锁新招按钮 */
.action-card {
  background: var(--bg-surface);
  border-radius: 0;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
  display: flex;
  align-items: center;
}

.action-card:active {
  background: var(--bg-card);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.action-emoji {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.action-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: var(--shadow-text-bold);
}

.action-arrow {
  font-size: 40rpx;
  color: var(--text-primary);
  font-weight: bold;
}
.timeline-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.timeline-header {
  margin-bottom: 24rpx;
}

.timeline-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: var(--shadow-text-bold);
}

.timeline-list {
  /* 样式由组件控制 */
}

/* 时光轴空状态 */
.timeline-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.timeline-empty .empty-emoji {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.timeline-empty .empty-text {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: var(--shadow-text);
  margin-bottom: 12rpx;
}

.timeline-empty .empty-hint {
  font-size: 24rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

/* 底部信息 */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: var(--text-primary);
  text-shadow: 2rpx 2rpx 0 #000;
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 20rpx;
  color: var(--text-secondary);
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 底部安全距离 */
.bottom-safe {
  height: calc(180rpx + env(safe-area-inset-bottom));
}
