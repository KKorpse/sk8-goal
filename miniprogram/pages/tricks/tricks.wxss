/* 动作库页面样式 - 优化版 */

.tricks-page {
  min-height: 100vh;
  background: transparent;
}

/* 顶部固定区域 */
.header-fixed {
  /* 泥土背景 */
  background-image:
    radial-gradient(circle at 25% 25%, rgba(74, 53, 32, 0.8) 2rpx, transparent 2rpx),
    radial-gradient(circle at 75% 75%, rgba(45, 30, 17, 0.6) 2rpx, transparent 2rpx);
  background-size: 24rpx 24rpx;
  background-color: var(--bg-dark);
  padding-bottom: var(--spacing-md);
  border-bottom: 4rpx solid #000;
}

/* 招式列表 */
.tricks-list {
  padding: 0 var(--spacing-lg);
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-yellow);
  border-radius: 0;
  animation: spin 1s steps(8, end) infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: var(--spacing-lg);
  font-size: var(--font-sm);
  color: var(--text-secondary-light);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 空状态 */
.empty-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-primary-light);
  margin-bottom: var(--spacing-md);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-secondary-light);
  font-weight: bold;
}

/* ===== 熟练度分组区域 ===== */
.status-section {
  padding: var(--spacing-lg) 0 var(--spacing-md);
}

.status-group {
  margin-bottom: var(--spacing-card);
}

/* 分组标题行 */
.status-group-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  padding: var(--spacing-lg) var(--spacing-inner);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.status-group-header.expanded {
  box-shadow: var(--shadow-pressed);
  background: var(--bg-card-hover);
}

.status-group-left {
  display: flex;
  align-items: center;
}

/* 图标容器 - MC 风格像素边框 */
.status-group-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  margin-right: var(--spacing-lg);
}

.status-group-emoji {
  font-size: var(--icon-lg);
}

/* 分组文字 */
.status-group-info {
  display: flex;
  flex-direction: column;
}

.status-group-label {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.status-group-count {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
  text-shadow: none;
}

/* 箭头 */
.status-group-arrow {
  transition: transform var(--transition-normal);
}

.status-group-arrow.rotated {
  transform: rotate(180deg);
}

.arrow-icon {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 可展开的列表体 - max-height 限制最多显示5个，超出可滚动 */
.status-group-body {
  max-height: 0;
  overflow: hidden;
  transition: max-height var(--transition-normal);
}

.status-group-body.show {
  /* 5个卡片高度 + 间距 + padding，约 5 * (120rpx + 24rpx) = 720rpx */
  max-height: 800rpx;
  overflow-y: auto;
  margin-top: var(--spacing-sm);
}

/* 列表容器 */
.status-group-list {
  padding: var(--spacing-sm) 0;
}

/* 分组内空状态 */
.status-group-empty {
  padding: var(--spacing-xl) 0;
  text-align: center;
}

.status-group-empty-text {
  font-size: var(--font-sm);
  color: var(--text-muted);
  text-shadow: none;
  font-style: italic;
}

/* ===== 分隔线 ===== */
.section-divider {
  display: flex;
  align-items: center;
  padding: var(--spacing-md) 0;
  margin-bottom: var(--spacing-sm);
}

.divider-line {
  flex: 1;
  height: 4rpx;
  background: var(--border-light);
}

.divider-text {
  padding: 0 var(--spacing-lg);
  font-size: var(--font-xs);
  color: var(--text-muted);
  font-weight: bold;
  text-shadow: none;
}

/* ===== 招式系列分组 ===== */
.trick-group {
  margin-bottom: var(--spacing-section);
}

.group-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) 8rpx;
}

.group-line {
  width: 16rpx;
  height: 32rpx;
  background: var(--primary-purple);
  border: 2rpx solid #000;
  margin-right: var(--spacing-md);
  box-shadow: 0 0 8rpx var(--primary-purple);
}

.group-title {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary-light);
  text-shadow: 2rpx 2rpx 0 #000;
}

.group-content {
  /* 卡片间距由组件自身控制 */
}

/* 底部安全距离 */
.bottom-safe {
  height: calc(200rpx + env(safe-area-inset-bottom));
}
