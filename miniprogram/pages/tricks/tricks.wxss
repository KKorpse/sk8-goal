/* 动作库页面样式 */

.tricks-page {
  min-height: 100vh;
  background: transparent;
}

/* 顶部固定区域 */
.header-fixed {
  position: sticky;
  top: 0;
  z-index: 100;
  /* 泥土背景 */
  background-image: 
    radial-gradient(#2d1e11 15%, transparent 16%),
    radial-gradient(#2d1e11 15%, transparent 16%);
  background-size: 32rpx 32rpx;
  background-position: 0 0, 16rpx 16rpx;
  background-color: var(--bg-dark);
  padding-bottom: 10rpx;
  border-bottom: 4rpx solid #000;
}

/* 招式列表 */
.tricks-list {
  padding: 0 20rpx;
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-yellow);
  border-radius: 0;
  animation: spin 1s steps(8, end) infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

/* 空状态 */
.empty-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: bold;
  text-shadow: var(--shadow-text);
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: bold;
}

/* 招式分组 */
.trick-group {
  margin-bottom: 32rpx;
}

.group-header {
  display: flex;
  align-items: center;
  padding: 20rpx 8rpx;
}

.group-line {
  width: 16rpx;
  height: 32rpx;
  background: var(--primary-purple);
  border: 2rpx solid #000;
  margin-right: 16rpx;
}

.group-title {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: var(--shadow-text);
}

.group-content {
  /* 卡片间距由组件自身控制 */
}

/* 底部安全距离 */
.bottom-safe {
  height: calc(200rpx + env(safe-area-inset-bottom));
}
