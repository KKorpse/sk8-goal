/* 动作库页面样式 - 优化版 */

.tricks-page {
  min-height: 100vh;
  background: transparent;
}

/* 顶部固定区域 */
.header-fixed {
  /* 泥土背景 */
  background-image: 
    radial-gradient(circle at 25% 25%, rgba(74, 53, 32, 0.8) 2rpx, transparent 2rpx),
    radial-gradient(circle at 75% 75%, rgba(45, 30, 17, 0.6) 2rpx, transparent 2rpx);
  background-size: 24rpx 24rpx;
  background-color: var(--bg-dark);
  padding-bottom: var(--spacing-md);
  border-bottom: 4rpx solid #000;
}

/* 招式列表 */
.tricks-list {
  padding: 0 var(--spacing-lg);
}

/* 加载状态 */
.loading-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid var(--border-color);
  border-top-color: var(--primary-yellow);
  border-radius: 0;
  animation: spin 1s steps(8, end) infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  margin-top: var(--spacing-lg);
  font-size: var(--font-sm);
  color: var(--text-secondary-light);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 空状态 */
.empty-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-emoji {
  font-size: 80rpx;
  margin-bottom: var(--spacing-lg);
}

.empty-text {
  font-size: var(--font-lg);
  color: var(--text-primary-light);
  margin-bottom: var(--spacing-md);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

.empty-hint {
  font-size: var(--font-sm);
  color: var(--text-secondary-light);
  font-weight: bold;
}

/* 招式分组 */
.trick-group {
  margin-bottom: var(--spacing-section);
}

.group-header {
  display: flex;
  align-items: center;
  padding: var(--spacing-lg) 8rpx;
}

.group-line {
  width: 16rpx;
  height: 32rpx;
  background: var(--primary-purple);
  border: 2rpx solid #000;
  margin-right: var(--spacing-md);
  box-shadow: 0 0 8rpx var(--primary-purple);
}

.group-title {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary-light);
  text-shadow: 2rpx 2rpx 0 #000;
}

.group-content {
  /* 卡片间距由组件自身控制 */
}

/* 底部安全距离 */
.bottom-safe {
  height: calc(200rpx + env(safe-area-inset-bottom));
}

/* ========== MC 风格成就弹窗 ========== */
.achievement-popup {
  position: fixed;
  top: 120rpx;
  right: 20rpx;
  width: 560rpx;
  background: linear-gradient(135deg, #2d2d2d 0%, #1a1a1a 100%);
  border: 4rpx solid #5c3d0e;
  border-radius: 0;
  box-shadow: 
    0 0 20rpx rgba(0, 0, 0, 0.8),
    inset 0 0 20rpx rgba(255, 200, 100, 0.1),
    0 0 60rpx rgba(255, 180, 50, 0.3);
  overflow: hidden;
  transform: translateX(300px);
  opacity: 0;
  z-index: 9999;
}

.achievement-popup.show {
  transform: translateX(0);
  opacity: 1;
}

.achievement-content {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  position: relative;
  z-index: 1;
}

.achievement-icon {
  font-size: 72rpx;
  margin-right: 24rpx;
  filter: drop-shadow(0 0 8rpx rgba(255, 200, 100, 0.6));
}

.achievement-text {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.achievement-title {
  font-size: 20rpx;
  color: #ffc857;
  font-weight: bold;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  text-shadow: 2rpx 2rpx 0 #000;
  margin-bottom: 4rpx;
}

.achievement-name {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
  margin-bottom: 4rpx;
}

.achievement-desc {
  font-size: 22rpx;
  color: #b0b0b0;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 光泽效果 */
.achievement-shine {
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    90deg,
    transparent,
    rgba(255, 255, 255, 0.1),
    transparent
  );
  animation: shine 2s ease-in-out infinite;
}

@keyframes shine {
  0% {
    left: -100%;
  }
  50%, 100% {
    left: 100%;
  }
}
