.friends-page {
  min-height: 100vh;
  background: transparent;
  padding: var(--spacing-lg);
  padding-bottom: var(--safe-area-bottom-sm);
}

.friends-header {
  margin-bottom: var(--spacing-section);
}

.friends-title {
  display: block;
  font-size: var(--font-2xl);
  font-weight: bold;
  color: var(--text-primary-light);
  margin-bottom: 8rpx;
  text-shadow: none;
}

.friends-subtitle {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary-light);
}

.friends-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.friend-card {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: var(--spacing-inner);
}

.friend-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: var(--radius-md);
  border: 4rpx solid var(--border-color);
  background: var(--bg-card-light);
  box-shadow: var(--shadow-sm);
  flex-shrink: 0;
}

.friend-body {
  min-width: 0;
  flex: 1;
}

.friend-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
  margin-bottom: 10rpx;
}

.friend-name {
  font-size: var(--font-lg);
  font-weight: bold;
  color: var(--text-primary);
}

.friend-city {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  padding: 4rpx 12rpx;
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-full);
  flex-shrink: 0;
}

.friend-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 12rpx;
  margin-bottom: 10rpx;
}

.friend-stat {
  font-size: var(--font-sm);
  color: var(--text-primary-light);
  background: var(--bg-surface);
  border: 3rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  padding: 4rpx 12rpx;
}

.friend-tagline {
  display: block;
  font-size: var(--font-sm);
  color: var(--text-secondary);
  line-height: 1.5;
}

.bottom-safe {
  height: var(--safe-area-bottom-sm);
}
