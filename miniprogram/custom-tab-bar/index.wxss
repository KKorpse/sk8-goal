.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 160rpx; /* Taller to accommodate hotbar slots */
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: flex-end;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom));
  pointer-events: none; /* Let clicks pass through empty areas */
  z-index: 9999;
}

.tab-bar-container {
  display: flex;
  background: rgba(0, 0, 0, 0.4); /* Semi-transparent backing like hotbar */
  padding: 12rpx;
  border-radius: 4rpx;
  border: 4rpx solid #111;
  pointer-events: auto; /* Catch clicks on bar */
  backdrop-filter: blur(4px);
}

.tab-bar-item {
  position: relative;
  width: 110rpx;
  height: 110rpx;
  margin: 0 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.slot-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #8b8b8b;
  border: 4rpx solid #373737;
  border-top-color: #373737;
  border-left-color: #373737;
  border-bottom-color: #ffffff;
  border-right-color: #ffffff;
  box-shadow: inset 4rpx 4rpx 0 #000;
}

.slot-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}

.tab-icon {
  width: 50rpx;
  height: 50rpx;
  margin-bottom: 6rpx;
}

.tab-text {
  font-size: 20rpx;
  font-family: 'Courier New', monospace;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
  line-height: 1;
}

.selection-box {
  position: absolute;
  top: -8rpx;
  left: -8rpx;
  right: -8rpx;
  bottom: -8rpx;
  border: 6rpx solid #ffffff;
  z-index: 3;
  box-shadow: 0 0 8rpx rgba(0,0,0,0.5);
  pointer-events: none;
}