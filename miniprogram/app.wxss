/**
 * SkateGoal 全局样式
 */

@import "./styles/theme.wxss";

/* Reset */
page {
  background-color: var(--bg-dark);
  background-image: var(--page-background-image);
  background-size: 24rpx 24rpx;
  min-height: 100%;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  font-family: var(--font-family-base);
}

.theme-shell {
  min-height: 100vh;
  background-color: var(--bg-dark);
  background-image: var(--page-background-image);
  background-size: 24rpx 24rpx;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片基础样式 */
.card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: var(--spacing-inner);
  margin: var(--spacing-card);
  box-shadow: var(--shadow-md);
  position: relative;
}

.card::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  pointer-events: none;
}

.card::after {
  content: "";
  position: absolute;
  top: 4rpx; left: 4rpx; right: 4rpx; bottom: 4rpx;
  border: 4rpx solid var(--border-light);
  pointer-events: none;
}

.card-glow {
  box-shadow: var(--shadow-purple);
}

/* 胶囊标签 */
.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border: 4rpx solid var(--border-color);
  background: var(--bg-surface);
  color: var(--text-primary-light);
  font-size: var(--font-sm);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.pill-active {
  background: var(--bg-card);
  color: var(--text-primary);
  box-shadow: var(--shadow-pressed);
}

/* 状态点 - 优化辨识度 */
.status-dot {
  width: 18rpx;
  height: 18rpx;
  background: var(--status-none);
  border: 3rpx solid var(--border-color);
  transition: all var(--transition-fast);
}

.status-dot.trial {
  background: var(--status-trial);
  box-shadow: 0 0 8rpx var(--status-trial);
}

.status-dot.grinding {
  background: var(--status-grinding);
  box-shadow: 0 0 8rpx var(--status-grinding);
}

.status-dot.mastered {
  background: var(--status-mastered);
  box-shadow: 0 0 10rpx var(--status-mastered);
}

/* 文字样式 - 优化对比度 */
.text-primary {
  color: var(--text-primary);
}

.text-primary-light {
  color: var(--text-primary-light);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-yellow {
  color: var(--primary-yellow);
  text-shadow: var(--text-shadow-strong);
}

.text-purple {
  color: var(--primary-purple);
  text-shadow: var(--text-shadow-strong);
}

.text-cyan {
  color: var(--status-trial);
  text-shadow: var(--text-shadow-strong);
}

.text-orange {
  color: var(--status-grinding);
  text-shadow: var(--text-shadow-strong);
}

.text-green {
  color: var(--status-mastered);
  text-shadow: var(--text-shadow-strong);
}

/* 卡片内文字样式 */
.card-text {
  color: var(--text-primary);
  text-shadow: none;
}

.card-text-secondary {
  color: var(--text-secondary);
  text-shadow: none;
}

/* 字重 */
.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

/* 字号 - 使用变量 */
.text-xs {
  font-size: var(--font-xs);
}

.text-sm {
  font-size: var(--font-sm);
}

.text-base {
  font-size: var(--font-base);
}

.text-lg {
  font-size: var(--font-lg);
}

.text-xl {
  font-size: var(--font-xl);
}

.text-2xl {
  font-size: var(--font-2xl);
}

.text-3xl {
  font-size: var(--font-3xl);
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-sm {
  gap: var(--spacing-sm);
}

.gap-md {
  gap: var(--spacing-md);
}

.gap-lg {
  gap: var(--spacing-lg);
}

/* 间距 - 统一使用变量 */
.mt-sm {
  margin-top: var(--spacing-sm);
}

.mt-md {
  margin-top: var(--spacing-md);
}

.mt-lg {
  margin-top: var(--spacing-lg);
}

.mb-sm {
  margin-bottom: var(--spacing-sm);
}

.mb-md {
  margin-bottom: var(--spacing-md);
}

.mb-lg {
  margin-bottom: var(--spacing-lg);
}

.p-sm {
  padding: var(--spacing-sm);
}

.p-md {
  padding: var(--spacing-md);
}

.p-lg {
  padding: var(--spacing-lg);
}

/* 动画 - 添加过渡效果 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 10rpx var(--primary-yellow);
  }
  50% {
    box-shadow: 0 0 30rpx var(--primary-yellow), 0 0 60rpx var(--primary-yellow);
  }
}

@keyframes celebrate {
  0% { transform: scale(1); }
  25% { transform: scale(1.05); }
  50% { transform: scale(1); }
  75% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-bounce {
  animation: bounce 1s ease-in-out infinite;
}

.animate-glow {
  animation: glow 1.5s ease-in-out infinite;
}

.animate-celebrate {
  animation: celebrate 0.5s ease-out;
}

/* 状态切换动画 */
.fade-in {
  animation: fadeIn var(--transition-normal) ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 弹窗动画 */
.slide-up {
  animation: slideUp var(--transition-normal) ease-out;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

/* 骨架屏动画 */
@keyframes skeleton {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton {
  background: linear-gradient(90deg, var(--bg-surface) 25%, var(--bg-card) 50%, var(--bg-surface) 75%);
  background-size: 200% 100%;
  animation: skeleton 1.5s infinite;
}
