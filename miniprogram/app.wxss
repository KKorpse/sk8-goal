/**
 * SkateGoal 全局样式
 * 荒野乱斗风格配色方案
 */

@import "./styles/theme.wxss";

/* Reset */
page {
  background-color: var(--bg-dark);
  min-height: 100%;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Helvetica Neue', sans-serif;
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片基础样式 */
.card {
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 28rpx;
  margin: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
}

.card-glow {
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.2);
}

/* 胶囊标签 */
.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  background: var(--bg-card-light);
  color: var(--text-secondary);
  font-size: 24rpx;
}

.pill-active {
  background: linear-gradient(135deg, var(--primary-purple), #6366F1);
  color: var(--text-primary);
  box-shadow: 0 4rpx 16rpx rgba(139, 92, 246, 0.4);
}

/* 状态点 */
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--border-color);
}

.status-dot.trial {
  background: var(--status-trial);
  box-shadow: 0 0 8rpx var(--status-trial);
}

.status-dot.grinding {
  background: var(--status-grinding);
  box-shadow: 0 0 8rpx var(--status-grinding);
}

.status-dot.mastered {
  background: var(--status-mastered);
  box-shadow: 0 0 8rpx var(--status-mastered);
}

/* 文字样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-yellow {
  color: var(--primary-yellow);
}

.text-purple {
  color: var(--primary-purple);
}

.text-cyan {
  color: var(--status-trial);
}

.text-orange {
  color: var(--status-grinding);
}

/* 字重 */
.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

/* 字号 */
.text-xs {
  font-size: 22rpx;
}

.text-sm {
  font-size: 26rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 40rpx;
}

.text-3xl {
  font-size: 48rpx;
}

.text-4xl {
  font-size: 56rpx;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-sm {
  gap: 12rpx;
}

.gap-md {
  gap: 20rpx;
}

.gap-lg {
  gap: 28rpx;
}

/* 间距 */
.mt-sm {
  margin-top: 12rpx;
}

.mt-md {
  margin-top: 20rpx;
}

.mt-lg {
  margin-top: 28rpx;
}

.mb-sm {
  margin-bottom: 12rpx;
}

.mb-md {
  margin-bottom: 20rpx;
}

.mb-lg {
  margin-bottom: 28rpx;
}

.p-sm {
  padding: 12rpx;
}

.p-md {
  padding: 20rpx;
}

.p-lg {
  padding: 28rpx;
}

/* 动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 10rpx var(--primary-yellow);
  }
  50% {
    box-shadow: 0 0 30rpx var(--primary-yellow), 0 0 60rpx var(--primary-yellow);
  }
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-bounce {
  animation: bounce 1s ease-in-out infinite;
}

.animate-glow {
  animation: glow 1.5s ease-in-out infinite;
}
