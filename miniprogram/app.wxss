/**
 * SkateGoal 全局样式
 * Minecraft 风格配色方案
 */

@import "./styles/theme.wxss";

/* Reset */
page {
  background-color: var(--bg-dark);
  /* 使用 CSS 绘制简单的泥土背景像素纹理 */
  background-image: 
    radial-gradient(#2d1e11 15%, transparent 16%),
    radial-gradient(#2d1e11 15%, transparent 16%);
  background-size: 32rpx 32rpx;
  background-position: 0 0, 16rpx 16rpx;
  min-height: 100%;
  font-size: 28rpx;
  line-height: 1.6;
  color: var(--text-primary);
  /* MC 风格一般要有文字阴影 */
  text-shadow: var(--shadow-text);
  font-family: 'Courier New', Courier, monospace, 'PingFang SC', sans-serif; /* 替换为等宽或者方正像素字体 */
}

/* 通用容器 */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片基础样式 - MC Stone UI */
.card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-md);
  padding: 28rpx;
  margin: 20rpx;
  box-shadow: var(--shadow-md);
  position: relative;
}

.card::before {
  content: "";
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  border: 4rpx solid #ffffff;
  pointer-events: none;
}

.card::after {
  content: "";
  position: absolute;
  top: 4rpx; left: 4rpx; right: 4rpx; bottom: 4rpx;
  border: 4rpx solid #555555;
  pointer-events: none;
}

.card-glow {
  box-shadow: var(--shadow-purple);
}

/* 胶囊标签 (改为 MC 按钮风格) */
.pill {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border: 4rpx solid var(--border-color);
  background: var(--bg-surface);
  color: var(--text-primary);
  font-size: 24rpx;
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.pill-active {
  background: var(--bg-card);
  color: var(--primary-yellow);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

/* 状态点 */
.status-dot {
  width: 16rpx;
  height: 16rpx;
  background: var(--border-color);
  border: 2rpx solid #000;
}

.status-dot.trial {
  background: var(--status-trial);
}

.status-dot.grinding {
  background: var(--status-grinding);
}

.status-dot.mastered {
  background: var(--status-mastered);
}

/* 文字样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-yellow {
  color: var(--primary-yellow);
}

.text-purple {
  color: var(--primary-purple);
}

.text-cyan {
  color: var(--status-trial);
}

.text-orange {
  color: var(--status-grinding);
}

/* 字重 */
.font-bold {
  font-weight: 700;
}

.font-semibold {
  font-weight: 600;
}

.font-medium {
  font-weight: 500;
}

/* 字号 */
.text-xs {
  font-size: 22rpx;
}

.text-sm {
  font-size: 26rpx;
}

.text-base {
  font-size: 28rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 36rpx;
}

.text-2xl {
  font-size: 40rpx;
}

.text-3xl {
  font-size: 48rpx;
}

.text-4xl {
  font-size: 56rpx;
}

/* Flex 布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.flex-row {
  flex-direction: row;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.flex-wrap {
  flex-wrap: wrap;
}

.gap-sm {
  gap: 12rpx;
}

.gap-md {
  gap: 20rpx;
}

.gap-lg {
  gap: 28rpx;
}

/* 间距 */
.mt-sm {
  margin-top: 12rpx;
}

.mt-md {
  margin-top: 20rpx;
}

.mt-lg {
  margin-top: 28rpx;
}

.mb-sm {
  margin-bottom: 12rpx;
}

.mb-md {
  margin-bottom: 20rpx;
}

.mb-lg {
  margin-bottom: 28rpx;
}

.p-sm {
  padding: 12rpx;
}

.p-md {
  padding: 20rpx;
}

.p-lg {
  padding: 28rpx;
}

/* 动画 */
@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.6;
  }
}

@keyframes bounce {
  0%, 100% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-10rpx);
  }
}

@keyframes glow {
  0%, 100% {
    box-shadow: 0 0 10rpx var(--primary-yellow);
  }
  50% {
    box-shadow: 0 0 30rpx var(--primary-yellow), 0 0 60rpx var(--primary-yellow);
  }
}

.animate-pulse {
  animation: pulse 2s ease-in-out infinite;
}

.animate-bounce {
  animation: bounce 1s ease-in-out infinite;
}

.animate-glow {
  animation: glow 1.5s ease-in-out infinite;
}
