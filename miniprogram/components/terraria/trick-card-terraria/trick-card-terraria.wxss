.terraria-trick-card {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  margin-bottom: var(--spacing-card);
}

.terraria-trick-card-active {
  transform: translateY(2rpx);
}

.slot-frame {
  border: 6rpx solid #1e2d14;
  background: #87603a;
  box-shadow: inset 0 0 0 4rpx #a57b4d;
}

.icon-slot {
  width: 112rpx;
  min-height: 112rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.14) 48rpx, transparent 48rpx),
    linear-gradient(rgba(0, 0, 0, 0.14) 48rpx, transparent 48rpx),
    #6c7d35;
  background-size: 48rpx 48rpx;
}

.detail-slot {
  flex: 1;
  padding: 14rpx;
  background:
    linear-gradient(90deg, rgba(0, 0, 0, 0.12) 48rpx, transparent 48rpx),
    linear-gradient(rgba(0, 0, 0, 0.12) 48rpx, transparent 48rpx),
    #5d4330;
  background-size: 48rpx 48rpx;
}

.slot-icon {
  font-size: 42rpx;
}

.detail-head {
  margin-bottom: 14rpx;
}

.trick-name {
  display: block;
  font-size: 28rpx;
  color: #fff4d0;
  font-weight: 700;
  line-height: 1.2;
}

.trick-name-cn {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #d9c6a6;
}

.ore-status-grid {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.ore-status-cell {
  flex: 1;
  text-align: center;
}

.ore-icon-slot {
  height: 48rpx;
  border: 4rpx solid #1e2d14;
  background: #3a3e43;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ore-icon {
  position: relative;
  width: 32rpx;
  height: 32rpx;
}

.ore-core,
.ore-shard {
  position: absolute;
  background: #4f5560;
}

.ore-core {
  inset: 8rpx;
}

.ore-shard.shard-a {
  width: 10rpx;
  height: 10rpx;
  left: 0;
  top: 10rpx;
}

.ore-shard.shard-b {
  width: 10rpx;
  height: 10rpx;
  right: 0;
  bottom: 6rpx;
}

.ore-icon.none .ore-core,
.ore-icon.none .ore-shard {
  background: #5b5f66;
}

.ore-icon.trial .ore-core {
  background: #6a6f78;
}

.ore-icon.trial .ore-shard {
  background: #8b9098;
}

.ore-icon.grinding .ore-core {
  background: #4f7f94;
}

.ore-icon.grinding .ore-shard {
  background: #82c2da;
}

.ore-icon.mastered .ore-core {
  background: #f2ce5d;
}

.ore-icon.mastered .ore-shard {
  background: #fff0a1;
}

.ore-label {
  display: block;
  margin-top: 6rpx;
  font-size: 18rpx;
  color: #efe0bd;
  font-weight: 700;
}
