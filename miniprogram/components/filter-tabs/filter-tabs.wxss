/* 筛选标签样式 */

.filter-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
}

.tabs-wrapper {
  display: inline-flex;
  gap: 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 0;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
  flex-shrink: 0;
}

.tab-item.active {
  background: var(--bg-surface);
  border-color: var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.tab-hover {
  transform: translateY(4rpx);
}

.tab-icon {
  font-size: 24rpx;
}

.tab-name {
  font-size: 26rpx;
  font-weight: bold;
  color: var(--text-dark);
  text-shadow: none;
}

.tab-item.active .tab-name {
  color: var(--primary-yellow);
  text-shadow: var(--shadow-text);
}
