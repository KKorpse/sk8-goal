/* 筛选标签样式 */

.filter-tabs {
  white-space: nowrap;
  padding: 16rpx 24rpx;
}

.tabs-wrapper {
  display: inline-flex;
  gap: 16rpx;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 28rpx;
  border-radius: 999rpx;
  background: var(--bg-card);
  border: 2rpx solid var(--border-color);
  transition: all 0.25s ease;
  flex-shrink: 0;
}

.tab-item.active {
  background: linear-gradient(135deg, var(--primary-purple), #6366F1);
  border-color: var(--primary-purple);
  box-shadow: 0 4rpx 20rpx rgba(139, 92, 246, 0.4);
}

.tab-hover {
  transform: scale(0.95);
  opacity: 0.9;
}

.tab-icon {
  font-size: 24rpx;
}

.tab-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-secondary);
}

.tab-item.active .tab-name {
  color: var(--text-primary);
}
