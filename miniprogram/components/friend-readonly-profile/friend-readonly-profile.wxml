<view class="readonly-profile-shell">
  <view class="readonly-profile-card">
    <view class="readonly-card-header">
      <view class="readonly-avatar-wrapper">
        <image
          class="readonly-avatar"
          src="{{friend.avatar}}"
          mode="aspectFill"
        />
      </view>

      <view class="readonly-user-info">
        <text class="readonly-nickname">{{friend.nickname}}</text>
        <text class="readonly-user-id">ID: {{friend.id}}</text>
        <text class="readonly-signature">{{friend.profile.signature}}</text>
      </view>

      <view class="readonly-header-right">
        <view class="readonly-header-tag">
          <text class="readonly-header-tag-text">脚位 {{friend.profile.stance === 'regular' ? 'Regular' : 'Goofy'}}</text>
        </view>
        <view class="readonly-header-tag">
          <text class="readonly-header-tag-text">板龄 {{friend.profile.yearsSkating}} 年</text>
        </view>
      </view>
    </view>

    <view class="readonly-badges-wrapper">
      <view class="readonly-badges-header">
        <text class="readonly-badges-title">成就徽章</text>
        <text class="readonly-badges-count">{{friend.profile.badgesUnlockedCount || 0}}/{{friend.profile.badges.length}}</text>
      </view>
      <scroll-view scroll-x class="readonly-badges-list">
        <view
          class="readonly-badge-item {{item.unlocked ? '' : 'locked'}}"
          wx:for="{{friend.profile.badges}}"
          wx:key="id"
        >
          <text class="readonly-badge-emoji">{{item.emoji}}</text>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="readonly-progress-card">
    <view class="progress-card-title">滑手数据</view>

    <readonly-ollie ollie="{{friend.profile.ollie}}" />

    <view class="progress-divider"></view>

    <view class="stats-row">
      <view class="stats-col mastered">
        <text class="stat-num">{{friend.profile.stats.masteredCount}}</text>
        <text class="stat-label">一脚一个</text>
      </view>
      <view class="stats-col-divider"></view>
      <view class="stats-col grinding">
        <text class="stat-num">{{friend.profile.stats.grindingCount}}</text>
        <text class="stat-label">死磕中</text>
      </view>
      <view class="stats-col-divider"></view>
      <view class="stats-col trial">
        <text class="stat-num">{{friend.profile.stats.trialCount}}</text>
        <text class="stat-label">体验卡</text>
      </view>
      <view class="stats-col-divider"></view>
      <view class="stats-col">
        <text class="stat-num">{{friend.profile.monthlyCheckinDays}}</text>
        <text class="stat-label">本月打卡</text>
      </view>
    </view>
  </view>

  <view class="timeline-card">
    <view class="timeline-header">
      <text class="timeline-title">成招记录</text>
      <text class="readonly-timeline-count">{{friend.profile.timeline.length}} 条</text>
    </view>
    <achievement-scene
      timeline="{{friend.profile.timeline}}"
      scene-config="{{readonlySceneConfig}}"
    />
  </view>
</view>
