.readonly-profile-shell {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.readonly-profile-card,
.readonly-progress-card,
.timeline-card {
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

.readonly-profile-card {
  padding: 20rpx;
}

.readonly-card-header {
  display: flex;
  align-items: flex-start;
}

.readonly-avatar-wrapper {
  margin-right: 18rpx;
  flex-shrink: 0;
}

.readonly-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: var(--radius-md);
  border: 4rpx solid var(--border-color);
  background: var(--bg-card-light);
  box-shadow: var(--shadow-sm);
}

.readonly-user-info {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-width: 0;
}

.readonly-nickname {
  font-size: var(--font-xl);
  font-weight: bold;
  color: var(--text-primary);
  line-height: 1.2;
}

.readonly-user-id {
  margin-top: 6rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: var(--text-secondary);
}

.readonly-signature {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: var(--text-secondary);
}

.readonly-header-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  margin-left: 14rpx;
  flex-shrink: 0;
}

.readonly-header-tag {
  min-width: 144rpx;
  padding: 8rpx 14rpx;
  background: var(--bg-surface);
  border: 3rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
}

.readonly-header-tag-text {
  font-size: 19rpx;
  font-weight: bold;
  color: var(--text-primary-light);
}

.readonly-badges-wrapper {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-pressed);
}

.readonly-badges-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.readonly-badges-title,
.progress-card-title,
.timeline-title {
  font-size: 24rpx;
  font-weight: bold;
  color: var(--text-primary);
}

.readonly-badges-count,
.readonly-timeline-count {
  font-size: 18rpx;
  font-weight: bold;
  color: var(--text-secondary-light);
}

.readonly-badges-list {
  white-space: nowrap;
}

.readonly-badges-list::-webkit-scrollbar {
  display: none;
}

.readonly-badge-item {
  width: 56rpx;
  height: 56rpx;
  margin-right: 12rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  vertical-align: top;
}

.readonly-badge-item.locked {
  background: var(--bg-surface-dark);
}

.readonly-badge-item.locked .readonly-badge-emoji {
  opacity: 0.35;
  filter: grayscale(1);
}

.readonly-badge-emoji {
  font-size: 28rpx;
}

.readonly-progress-card,
.timeline-card {
  padding: 18rpx 20rpx;
}

.progress-card-title {
  margin-bottom: 16rpx;
}

.progress-divider {
  height: 4rpx;
  background: var(--border-color);
  margin: 16rpx 0 14rpx;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stats-col {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 0;
}

.stat-num {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--primary-yellow);
  font-variant-numeric: tabular-nums;
}

.stat-label {
  font-size: 18rpx;
  font-weight: bold;
  color: var(--text-secondary);
}

.stats-col.mastered .stat-num {
  color: var(--primary-green);
}

.stats-col.grinding .stat-num {
  color: var(--primary-orange);
}

.stats-col.trial .stat-num {
  color: var(--primary-cyan);
}

.stats-col-divider {
  width: 4rpx;
  height: 52rpx;
  background: var(--border-color);
  flex-shrink: 0;
}

.timeline-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
