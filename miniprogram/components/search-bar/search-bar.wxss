/* 搜索栏样式 */

.search-bar {
  padding: 16rpx 24rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg-surface);
  border-radius: 0;
  padding: 0 24rpx;
  height: 80rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

.search-bar.focused .search-input-wrapper {
  border-color: var(--primary-yellow);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: var(--text-dark);
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
  text-shadow: var(--shadow-text);
}

.search-placeholder {
  color: var(--text-dark);
  font-size: 28rpx;
  text-shadow: none;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  box-shadow: inset 2rpx 2rpx 0px 0px #ffffff, inset -2rpx -2rpx 0px 0px #555555;
  opacity: 0;
  transform: scale(0.8);
}

.clear-btn.show {
  opacity: 1;
  transform: scale(1);
}

.clear-icon {
  font-size: 24rpx;
  color: var(--text-dark);
  line-height: 1;
}
