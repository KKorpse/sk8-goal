/* 搜索栏样式 */

.search-bar {
  padding: 16rpx 24rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background: var(--bg-surface);
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 80rpx;
  border: 2rpx solid var(--border-color);
  transition: all 0.3s ease;
}

.search-bar.focused .search-input-wrapper {
  border-color: var(--primary-purple);
  box-shadow: 0 0 20rpx rgba(139, 92, 246, 0.3);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  opacity: 0.7;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 28rpx;
  color: var(--text-primary);
}

.search-placeholder {
  color: var(--text-muted);
  font-size: 28rpx;
}

.clear-btn {
  width: 44rpx;
  height: 44rpx;
  background: var(--bg-card-light);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  opacity: 0;
  transform: scale(0.8);
  transition: all 0.2s ease;
}

.clear-btn.show {
  opacity: 1;
  transform: scale(1);
}

.clear-icon {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1;
}
