/* 脚位矩阵面板样式 */

.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  opacity: 0;
  backdrop-filter: blur(4rpx);
}

.panel-mask.show {
  opacity: 1;
}

/* 成就达成动画 */
@keyframes celebrateGlow {
  0% { box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555; }
  50% { box-shadow: inset 8rpx 8rpx 0px 0px #ffffff, inset -8rpx -8rpx 0px 0px #555555, 0 0 20rpx var(--status-mastered); }
  100% { box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555; }
}

.stance-cell.mastered.just-mastered {
  animation: celebrateGlow 0.6s ease-out;
}

.panel-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-top: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: 0 0 calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

/* 拖拽条 */
.drag-bar {
  display: flex;
  justify-content: center;
  padding: 20rpx 0 10rpx;
}

.drag-indicator {
  width: 60rpx;
  height: 8rpx;
  background: var(--text-dark);
  border-radius: 0;
  border: 2rpx solid #000;
}

/* 标题栏 */
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  border-bottom: 4rpx solid var(--border-color);
  background: var(--bg-surface);
  box-shadow: inset 0 -4rpx 0 0 #555555;
}

.header-left {
  display: flex;
  align-items: center;
}

.trick-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.trick-titles {
  display: flex;
  flex-direction: column;
}

.trick-name {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: var(--shadow-text);
}

.trick-name-cn {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
  text-shadow: none;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  background: var(--primary-red);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 4rpx 4rpx 0px 0px #ffaaaa, inset -4rpx -4rpx 0px 0px #aa0000;
}

.close-btn:active {
  box-shadow: inset 4rpx 4rpx 0px 0px #aa0000, inset -4rpx -4rpx 0px 0px #ffaaaa;
}

.close-icon {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}

/* 脚位矩阵 */
.stance-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 28rpx;
}

.stance-cell {
  background: var(--bg-card-light);
  border-radius: 0;
  padding: 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.stance-cell.expanded {
  background: var(--bg-surface);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

/* 状态高亮边框 */
.stance-cell.trial {
  border-color: var(--status-trial);
}

.stance-cell.grinding {
  border-color: var(--status-grinding);
}

.stance-cell.mastered {
  border-color: var(--status-mastered);
}

.stance-info {
  margin-bottom: 16rpx;
}

.stance-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-dark);
}

.stance-name-cn {
  font-size: 22rpx;
  color: var(--text-dark);
  margin-left: 8rpx;
}

.current-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-emoji {
  font-size: 32rpx;
}

.status-text {
  font-size: 24rpx;
  color: var(--text-dark);
  font-weight: bold;
}

/* 状态选择器 */
.status-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 4rpx solid var(--border-color);
}

.status-option {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 12rpx 20rpx;
  border-radius: 0;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: inset 2rpx 2rpx 0px 0px #ffffff, inset -2rpx -2rpx 0px 0px #555555;
}

.status-option.active {
  box-shadow: inset 2rpx 2rpx 0px 0px #555555, inset -2rpx -2rpx 0px 0px #ffffff;
  background: var(--bg-card);
}

.status-option.trial {
  border-color: var(--status-trial);
}

.status-option.grinding {
  border-color: var(--status-grinding);
}

.status-option.mastered {
  border-color: var(--status-mastered);
}

.option-emoji {
  font-size: 24rpx;
}

.option-text {
  font-size: 22rpx;
  color: var(--text-primary);
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 底部提示 */
.panel-footer {
  text-align: center;
  padding: 20rpx;
}

.footer-hint {
  font-size: 22rpx;
  color: var(--text-dark);
  font-weight: bold;
}
