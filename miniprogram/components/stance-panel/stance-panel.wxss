/* 脚位矩阵面板样式 - 优化版 */

.panel-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  opacity: 0;
  backdrop-filter: blur(8rpx);
  transition: opacity var(--transition-normal);
}

.panel-mask.show {
  opacity: 1;
}

/* 成就达成动画 */
@keyframes celebrateGlow {
  0% { box-shadow: var(--shadow-sm); }
  50% { 
    box-shadow: 
      var(--shadow-lg), 
      0 0 30rpx var(--status-mastered),
      0 0 60rpx rgba(34, 170, 68, 0.3);
  }
  100% { box-shadow: var(--shadow-sm); }
}

@keyframes celebrateScale {
  0% { transform: scale(1); }
  25% { transform: scale(1.05); }
  50% { transform: scale(1); }
  75% { transform: scale(1.02); }
  100% { transform: scale(1); }
}

.stance-cell.mastered.just-mastered {
  animation: 
    celebrateGlow 0.8s ease-out,
    celebrateScale 0.5s ease-out;
}

.panel-container {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  background: var(--bg-card);
  border-top: 4rpx solid var(--border-color);
  border-radius: 0;
  padding: 0 0 calc(40rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 
    var(--shadow-lg),
    0 -10rpx 40rpx rgba(0, 0, 0, 0.3);
}

/* 拖拽条 */
.drag-bar {
  display: flex;
  justify-content: center;
  padding: var(--spacing-lg) 0 var(--spacing-sm);
}

.drag-indicator {
  width: 60rpx;
  height: 8rpx;
  background: var(--text-dark);
  border-radius: 0;
  border: 2rpx solid #000;
}

/* 标题栏 */
.panel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-lg) var(--spacing-inner);
  border-bottom: 4rpx solid var(--border-color);
  background: var(--bg-surface);
  box-shadow: inset 0 -4rpx 0 0 #555555;
}

.header-left {
  display: flex;
  align-items: center;
}

.trick-icon {
  font-size: var(--icon-xl);
  margin-right: var(--spacing-lg);
}

.trick-titles {
  display: flex;
  flex-direction: column;
}

.trick-name {
  font-size: var(--font-xl);
  font-weight: bold;
  color: var(--primary-yellow);
  text-shadow: 2rpx 2rpx 0 #000;
}

.trick-name-cn {
  font-size: var(--font-sm);
  color: var(--text-secondary-light);
  margin-top: 4rpx;
  text-shadow: none;
}

.close-btn {
  width: 64rpx;
  height: 64rpx;
  background: var(--primary-red);
  border: 4rpx solid var(--border-color);
  border-radius: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: inset 4rpx 4rpx 0px 0px #ffaaaa, inset -4rpx -4rpx 0px 0px #aa0000;
  transition: all var(--transition-fast);
}

.close-btn:active {
  box-shadow: inset 4rpx 4rpx 0px 0px #aa0000, inset -4rpx -4rpx 0px 0px #ffaaaa;
  transform: scale(0.95);
}

.close-icon {
  font-size: 40rpx;
  color: white;
  font-weight: bold;
  line-height: 1;
}

/* 脚位矩阵 */
.stance-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--spacing-lg);
  padding: var(--spacing-inner);
}

.stance-cell {
  background: var(--bg-card-light);
  border-radius: 0;
  padding: var(--spacing-lg);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.stance-cell.expanded {
  background: var(--bg-surface);
  box-shadow: var(--shadow-pressed);
}

/* 状态高亮边框 - 增强视觉效果 */
.stance-cell.trial {
  border-color: var(--status-trial);
  box-shadow: 
    var(--shadow-sm),
    0 0 15rpx var(--status-trial-bg);
}

.stance-cell.grinding {
  border-color: var(--status-grinding);
  box-shadow: 
    var(--shadow-sm),
    0 0 15rpx var(--status-grinding-bg);
}

.stance-cell.mastered {
  border-color: var(--status-mastered);
  box-shadow: 
    var(--shadow-sm),
    0 0 15rpx var(--status-mastered-bg);
}

.stance-info {
  margin-bottom: var(--spacing-md);
}

.stance-name {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.stance-name-cn {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-left: 8rpx;
}

.current-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-emoji {
  font-size: var(--icon-md);
}

.status-text {
  font-size: var(--font-sm);
  color: var(--text-primary);
  font-weight: bold;
  text-shadow: none;
}

/* 状态选择器 */
.status-selector {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-lg);
  border-top: 4rpx solid var(--border-color);
}

.status-option {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: var(--spacing-md) 20rpx;
  border-radius: 0;
  background: var(--bg-surface);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.status-option.active {
  box-shadow: var(--shadow-pressed);
  background: var(--bg-card);
}

.status-option.trial {
  border-color: var(--status-trial);
}

.status-option.trial.active {
  background: var(--status-trial-bg);
}

.status-option.grinding {
  border-color: var(--status-grinding);
}

.status-option.grinding.active {
  background: var(--status-grinding-bg);
}

.status-option.mastered {
  border-color: var(--status-mastered);
}

.status-option.mastered.active {
  background: var(--status-mastered-bg);
}

.option-emoji {
  font-size: var(--font-sm);
}

.option-text {
  font-size: var(--font-xs);
  color: var(--text-primary);
  text-shadow: none;
}

/* 底部提示 */
.panel-footer {
  text-align: center;
  padding: var(--spacing-lg);
  border-top: 4rpx solid var(--border-color);
  background: var(--bg-surface);
  margin-top: var(--spacing-md);
}

.footer-hint {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  font-weight: bold;
}
