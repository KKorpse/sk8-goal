/* 招式卡片组件样式 */

.trick-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: 0;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-sm);
  border: 4rpx solid var(--border-color);
}

.trick-card-hover {
  transform: scale(0.98);
  box-shadow: inset 4rpx 4rpx 0px 0px #555555, inset -4rpx -4rpx 0px 0px #ffffff;
}

/* 左侧 */
.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.trick-icon {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-card-light);
  border-radius: 0;
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

.icon-text {
  font-size: 40rpx;
}

.trick-info {
  display: flex;
  flex-direction: column;
}

.trick-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.trick-name-cn {
  font-size: 24rpx;
  color: var(--text-dark);
  margin-top: 4rpx;
  text-shadow: none;
}

/* 右侧 - 脚位状态 */
.card-right {
  display: flex;
  align-items: center;
}

.stance-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stance-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 0;
  border: 2rpx solid #000;
  background: var(--status-none);
}

.stance-dot.none {
  background: var(--status-none);
}

.stance-dot.trial {
  background: var(--status-trial);
}

.stance-dot.grinding {
  background: var(--status-grinding);
}

.stance-dot.mastered {
  background: var(--status-mastered);
}

.stance-abbr {
  font-size: 18rpx;
  color: var(--text-dark);
  font-weight: bold;
  text-shadow: none;
}
