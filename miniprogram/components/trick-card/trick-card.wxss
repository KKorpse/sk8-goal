/* 招式卡片组件样式 */

.trick-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.25);
  transition: all 0.2s ease;
  border: 2rpx solid transparent;
}

.trick-card-hover {
  transform: scale(1.02);
  border-color: var(--primary-purple);
  box-shadow: 0 8rpx 32rpx rgba(139, 92, 246, 0.3);
}

/* 左侧 */
.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.trick-icon {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-card-light);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 40rpx;
}

.trick-info {
  display: flex;
  flex-direction: column;
}

.trick-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
}

.trick-name-cn {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 4rpx;
}

/* 右侧 - 脚位状态 */
.card-right {
  display: flex;
  align-items: center;
}

.stance-dots {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.stance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stance-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: var(--status-none);
  transition: all 0.3s ease;
}

.stance-dot.none {
  background: var(--status-none);
}

.stance-dot.trial {
  background: var(--status-trial);
  box-shadow: 0 0 10rpx var(--status-trial);
}

.stance-dot.grinding {
  background: var(--status-grinding);
  box-shadow: 0 0 10rpx var(--status-grinding);
}

.stance-dot.mastered {
  background: var(--status-mastered);
  box-shadow: 0 0 12rpx var(--status-mastered);
}

.stance-abbr {
  font-size: 18rpx;
  color: var(--text-muted);
  font-weight: 500;
}
