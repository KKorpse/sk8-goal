/* 招式卡片组件样式 - 优化版 */

.trick-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  padding: var(--spacing-lg) var(--spacing-inner);
  margin-bottom: var(--spacing-card);
  box-shadow: var(--shadow-sm);
  border: 4rpx solid var(--border-color);
  transition: all var(--transition-fast);
}

.trick-card-hover {
  transform: scale(0.98);
  box-shadow: var(--shadow-pressed);
  background: var(--bg-card-hover);
}

/* 左侧 */
.card-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.trick-icon {
  width: 80rpx;
  height: 80rpx;
  background: var(--bg-card-light);
  border-radius: var(--radius-md);
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
}

.icon-text {
  font-size: var(--icon-md);
}

.trick-info {
  display: flex;
  flex-direction: column;
}

.trick-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.3;
  text-shadow: none;
}

.trick-name-cn {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  margin-top: 4rpx;
  text-shadow: none;
}

/* 右侧 - 脚位状态 */
.card-right {
  display: flex;
  align-items: center;
}

.stance-dots {
  display: flex;
  align-items: center;
  gap: var(--spacing-md);
}

.stance-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.stance-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: var(--radius-sm);
  border: 3rpx solid var(--border-color);
  background: var(--status-none);
  transition: all var(--transition-fast);
}

.stance-dot.none {
  background: var(--status-none);
}

.stance-dot.trial {
  background: var(--status-trial);
  box-shadow: 0 0 8rpx var(--status-trial);
}

.stance-dot.grinding {
  background: var(--status-grinding);
  box-shadow: 0 0 8rpx var(--status-grinding);
}

.stance-dot.mastered {
  background: var(--status-mastered);
  box-shadow: 0 0 10rpx var(--status-mastered);
}

.stance-abbr {
  font-size: 18rpx;
  color: var(--text-secondary);
  font-weight: bold;
  text-shadow: none;
}
