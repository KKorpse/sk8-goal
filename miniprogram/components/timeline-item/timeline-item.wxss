/* 时光轴条目样式 */

.timeline-item {
  display: flex;
  min-height: 140rpx;
}

/* 左侧 */
.timeline-left {
  display: flex;
  align-items: flex-start;
  width: 180rpx;
  flex-shrink: 0;
}

.date-wrapper {
  width: 120rpx;
  padding-top: 20rpx;
}

.date-text {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 时间轴轨道 */
.timeline-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.line-top,
.line-bottom {
  width: 6rpx;
  background: var(--text-dark);
  border-left: 2rpx solid #000;
  border-right: 2rpx solid #000;
}

.line-top {
  height: 30rpx;
}

.line-bottom {
  flex: 1;
  min-height: 60rpx;
}

.line-top.hidden,
.line-bottom.hidden {
  opacity: 0;
}

.node {
  width: 40rpx;
  height: 40rpx;
  border-radius: 0;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  box-shadow: inset 2rpx 2rpx 0px 0px #ffffff, inset -2rpx -2rpx 0px 0px #555555;
}

.node-emoji {
  font-size: 20rpx;
}

/* 节点状态样式 */
.node.trial {
  background: var(--status-trial);
}

.node.grinding {
  background: var(--status-grinding);
}

.node.mastered {
  width: 48rpx;
  height: 48rpx;
  background: var(--status-mastered);
}

.node.mastered .node-emoji {
  font-size: 24rpx;
}

/* 右侧内容 */
.timeline-right {
  flex: 1;
  padding: 10rpx 20rpx 10rpx 0;
}

.content-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: 20rpx 24rpx;
  border: 4rpx solid var(--border-color);
  box-shadow: inset 4rpx 4rpx 0px 0px #ffffff, inset -4rpx -4rpx 0px 0px #555555;
}

/* 卡片状态样式 */
.content-card.trial {
  border-color: var(--status-trial);
}

.content-card.grinding {
  border-color: var(--status-grinding);
}

.content-card.mastered {
  border-color: var(--status-mastered);
  background: var(--bg-card-light);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.trick-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: var(--shadow-text);
}

.stance-tag {
  font-size: 20rpx;
  color: var(--text-primary);
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
  padding: 4rpx 12rpx;
  border-radius: 0;
}

.card-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-emoji {
  font-size: 24rpx;
}

.status-text {
  font-size: 24rpx;
  color: var(--text-dark);
  font-weight: bold;
}

/* mastered 状态的文字高亮 */
.timeline-item.mastered .status-text {
  color: var(--status-mastered);
  text-shadow: 2rpx 2rpx 0 #000;
}
