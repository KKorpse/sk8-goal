/* 时光轴条目样式 - 优化版 */

.timeline-item {
  display: flex;
  min-height: 140rpx;
}

/* 左侧 */
.timeline-left {
  display: flex;
  align-items: flex-start;
  width: 180rpx;
  flex-shrink: 0;
}

.date-wrapper {
  width: 120rpx;
  padding-top: var(--spacing-lg);
}

.date-text {
  font-size: var(--font-xs);
  color: var(--text-secondary-light);
  font-weight: bold;
  text-shadow: 2rpx 2rpx 0 #000;
}

/* 时间轴轨道 */
.timeline-track {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 60rpx;
}

.line-top,
.line-bottom {
  width: 6rpx;
  background: var(--text-dark);
  border-left: 2rpx solid #000;
  border-right: 2rpx solid #000;
}

.line-top {
  height: 30rpx;
}

.line-bottom {
  flex: 1;
  min-height: 60rpx;
}

.line-top.hidden,
.line-bottom.hidden {
  opacity: 0;
}

.node {
  width: 40rpx;
  height: 40rpx;
  border-radius: 0;
  background: var(--bg-card);
  border: 4rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

.node-emoji {
  font-size: 20rpx;
}

/* 节点状态样式 - 增强视觉效果 */
.node.trial {
  background: var(--status-trial);
  box-shadow: 
    var(--shadow-sm),
    0 0 12rpx var(--status-trial);
}

.node.grinding {
  background: var(--status-grinding);
  box-shadow: 
    var(--shadow-sm),
    0 0 12rpx var(--status-grinding);
}

.node.mastered {
  width: 48rpx;
  height: 48rpx;
  background: var(--status-mastered);
  box-shadow: 
    var(--shadow-sm),
    0 0 15rpx var(--status-mastered);
}

.node.mastered .node-emoji {
  font-size: var(--font-sm);
}

/* 右侧内容 */
.timeline-right {
  flex: 1;
  padding: 10rpx var(--spacing-lg) 10rpx 0;
}

.content-card {
  background: var(--bg-card);
  border-radius: 0;
  padding: var(--spacing-lg) var(--spacing-inner);
  border: 4rpx solid var(--border-color);
  box-shadow: var(--shadow-sm);
  transition: all var(--transition-fast);
}

/* 卡片状态样式 - 增强视觉效果 */
.content-card.trial {
  border-color: var(--status-trial);
  box-shadow: 
    var(--shadow-sm),
    0 0 15rpx var(--status-trial-bg);
}

.content-card.grinding {
  border-color: var(--status-grinding);
  box-shadow: 
    var(--shadow-sm),
    0 0 15rpx var(--status-grinding-bg);
}

.content-card.mastered {
  border-color: var(--status-mastered);
  background: var(--bg-card-light);
  box-shadow: 
    var(--shadow-sm),
    0 0 20rpx var(--status-mastered-bg);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
}

.trick-name {
  font-size: var(--font-base);
  font-weight: bold;
  color: var(--text-primary);
  text-shadow: none;
}

.stance-tag {
  font-size: 18rpx;
  color: var(--text-primary);
  background: var(--bg-surface);
  border: 2rpx solid var(--border-color);
  padding: 4rpx var(--spacing-md);
  border-radius: 0;
}

.card-status {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.status-emoji {
  font-size: var(--font-sm);
}

.status-text {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  font-weight: bold;
}

/* mastered 状态的文字高亮 */
.timeline-item.mastered .status-text {
  color: var(--status-mastered);
  text-shadow: 2rpx 2rpx 0 #000;
}

.timeline-item.trial .status-text {
  color: var(--status-trial);
  text-shadow: 2rpx 2rpx 0 #000;
}

.timeline-item.grinding .status-text {
  color: var(--status-grinding);
  text-shadow: 2rpx 2rpx 0 #000;
}
